@model IEnumerable<AssetManagement.Application.ViewModels.Platform.PlatformUserListItemVm>
@using AssetManagement.Web.Helpers

@if (Model == null || !Model.Any())
{
    <div class="am-empty-state py-4 px-3">
        <p class="text-muted mb-0">No users in this category match the current filters.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Employee #</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Scope</th>
                    <th>Organization</th>
                    <th>Department</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.EmployeeNumber</td>
                    <td>@user.FirstName @user.LastName</td>
                    <td>@user.Email</td>
                    <td>
                        @if (user.IsSystemUser)
                        {
                            <span class="badge bg-dark">System</span>
                        }
                        else
                        {
                            <span class="badge bg-primary">Company</span>
                        }
                    </td>
                    <td>@(user.IsSystemUser ? DisplayText.Empty : (string.IsNullOrWhiteSpace(user.OrganizationName) ? DisplayText.Empty : user.OrganizationName))</td>
                    <td>@(string.IsNullOrWhiteSpace(user.DepartmentName) ? DisplayText.Empty : user.DepartmentName)</td>
                    <td>@user.RoleName</td>
                    <td><span class="badge bg-@StatusHtmlHelpers.ToBadgeClass(user.IsActive)">@(user.IsActive ? "Active" : "Inactive")</span></td>
                    <td><a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", new { id = user.Id })">Details</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
