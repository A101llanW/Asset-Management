@using AssetManagement.Application.ViewModels.Organizations
@using AssetManagement.Domain.Enums
@model LicenseIndexViewModel
@{
    ViewBag.Title = "Licenses";
    Layout = "~/Areas/Platform/Views/Shared/_PlatformLayout.cshtml";
    Func<LicenseStatus, string> statusClass = status =>
    {
        switch (status)
        {
            case LicenseStatus.Active:
                return "bg-success";
            case LicenseStatus.Paused:
                return "bg-warning text-dark";
            case LicenseStatus.Expired:
                return "bg-danger";
            case LicenseStatus.PendingRenewal:
                return "bg-info text-dark";
            default:
                return "bg-secondary";
        }
    };
    Func<LicenseListItemVm, string> flashcardBorderClass = item =>
    {
        switch (item.EffectiveStatus)
        {
            case LicenseStatus.Expired:
                return "am-license-flashcard--inactive";
            case LicenseStatus.Paused:
                return "am-license-flashcard--paused";
            case LicenseStatus.PendingRenewal:
                return "am-license-flashcard--expiring";
            case LicenseStatus.Active:
                return item.DaysRemaining <= 30 ? "am-license-flashcard--expiring" : "am-license-flashcard--active";
            default:
                return string.Empty;
        }
    };
    Func<LicenseListItemVm, string> expiryValueClass = item =>
    {
        if (item.EffectiveStatus == LicenseStatus.Expired)
        {
            return "am-license-flashcard__expiry-value--danger";
        }

        if (item.EffectiveStatus == LicenseStatus.PendingRenewal || item.DaysRemaining <= 30)
        {
            return "am-license-flashcard__expiry-value--warning";
        }

        return string.Empty;
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Platform Licenses</h1>
    <span class="text-muted small">@Model.TotalCount total</span>
</div>

<div class="card card-kpi mb-4">
    <div class="card-header">Filters</div>
    <div class="card-body">
        <form method="get" action="@Url.Action("Index", "Licenses", new { area = "Platform" })" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Search</label>
                <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Organization name or slug" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select name="status" class="form-select">
                    <option value="">All</option>
                    <option value="Active" @(Model.Status == "Active" ? "selected" : null)>Active</option>
                    <option value="Paused" @(Model.Status == "Paused" ? "selected" : null)>Paused</option>
                    <option value="Expired" @(Model.Status == "Expired" ? "selected" : null)>Expired</option>
                    <option value="PendingRenewal" @(Model.Status == "PendingRenewal" ? "selected" : null)>Pending renewal</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Expiring within</label>
                <select name="expiringWithinDays" class="form-select">
                    <option value="">Any</option>
                    <option value="30" @(Model.ExpiringWithinDays == 30 ? "selected" : null)>30 days</option>
                    <option value="60" @(Model.ExpiringWithinDays == 60 ? "selected" : null)>60 days</option>
                    <option value="90" @(Model.ExpiringWithinDays == 90 ? "selected" : null)>90 days</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Sort</label>
                <select name="sort" class="form-select">
                    <option value="expiry" @(Model.Sort == "expiry" ? "selected" : null)>Expiry</option>
                    <option value="organization" @(Model.Sort == "organization" ? "selected" : null)>Organization</option>
                    <option value="status" @(Model.Sort == "status" ? "selected" : null)>Status</option>
                </select>
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Apply</button>
            </div>
        </form>
    </div>
</div>

@if (Model.Items == null || !Model.Items.Any())
{
    <div class="card card-kpi">
        <div class="card-body am-empty-state">
            <h5>No licenses found</h5>
            <p class="text-muted mb-0">Try adjusting your filters or search terms.</p>
        </div>
    </div>
}
else
{
    <div class="am-license-flashcard-grid mb-4">
        @foreach (var item in Model.Items)
        {
            var isExpiringSoon = item.EffectiveStatus == LicenseStatus.Active && item.DaysRemaining <= 30;
            <article class="card card-kpi h-100 am-license-flashcard @flashcardBorderClass(item) am-fade-in">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                        <h2 class="am-license-flashcard__title">@item.OrganizationName</h2>
                        <span class="badge @statusClass(item.EffectiveStatus)">@item.EffectiveStatus</span>
                    </div>
                    <p class="text-muted small mb-3">Slug: <code class="am-tag-pill">/@item.OrganizationSlug</code></p>

                    <div class="am-license-flashcard__expiry">
                        <span class="small text-muted d-block">License expiry</span>
                        <p class="am-license-flashcard__expiry-value @expiryValueClass(item) mb-0">
                            @item.ExpiryDate.ToString("MMM dd, yyyy")
                        </p>
                        @if (item.EffectiveStatus == LicenseStatus.Expired)
                        {
                            <span class="badge bg-danger mt-1">Expired</span>
                        }
                        else if (item.EffectiveStatus == LicenseStatus.PendingRenewal || isExpiringSoon)
                        {
                            <span class="badge bg-warning text-dark mt-1">Expiring soon</span>
                        }
                    </div>

                    <dl class="am-license-flashcard__meta">
                        <div>
                            <dt>Days left</dt>
                            <dd>@item.DaysRemaining</dd>
                        </div>
                        <div>
                            <dt>Start</dt>
                            <dd>@item.StartDate.ToString("yyyy-MM-dd")</dd>
                        </div>
                        <div>
                            <dt>Max users</dt>
                            <dd>@(item.MaxUsers.HasValue ? item.MaxUsers.Value.ToString() : "Unlimited")</dd>
                        </div>
                    </dl>

                    <div class="mt-auto pt-2">
                        <a class="btn btn-outline-primary w-100" href="@Url.Action("Details", "Licenses", new { area = "Platform", orgId = item.OrganizationId })">Manage</a>
                    </div>
                </div>
            </article>
        }
    </div>

    <div class="card card-kpi">
        <div class="card-footer border-0 bg-transparent pt-0">
            @Html.Partial("_Pagination", new AssetManagement.Web.ViewModels.PaginationViewModel
            {
                Page = Model.Page,
                TotalPages = Model.TotalPages,
                TotalCount = Model.TotalCount,
                StartItem = Model.StartItem,
                EndItem = Model.EndItem
            })
        </div>
    </div>
}
