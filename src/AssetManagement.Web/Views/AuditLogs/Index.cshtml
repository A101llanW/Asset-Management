@model IEnumerable<AssetManagement.Application.ViewModels.AuditLogVm>
@{
    ViewBag.Title = "Audit Logs";
}
<h3>Audit Logs</h3>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-3"><input class="form-control" name="EntityType" placeholder="Entity Type" value="@Request.QueryString["EntityType"]" /></div>
    <div class="col-md-3"><input class="form-control" name="Action" placeholder="Action" value="@Request.QueryString["Action"]" /></div>
    <div class="col-md-2"><input class="form-control" type="date" name="FromDate" value="@Request.QueryString["FromDate"]" /></div>
    <div class="col-md-2"><input class="form-control" type="date" name="ToDate" value="@Request.QueryString["ToDate"]" /></div>
    <div class="col-md-2"><button class="btn btn-outline-primary" type="submit">Filter</button></div>
</form>
<div class="card card-kpi"><div class="card-body p-0">
<table class="table mb-0 table-sm">
    <thead class="table-light"><tr><th>Time</th><th>Actor</th><th>Action</th><th>Entity</th><th>Entity Id</th><th>IP</th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
            <td>@item.ActorUserId</td>
            <td>@item.Action</td>
            <td>@item.EntityType</td>
            <td>@item.EntityId</td>
            <td>@item.IPAddress</td>
        </tr>
    }
    </tbody>
</table>
</div></div>
