@model AssetManagement.Web.Models.LoginViewModel
@{
    ViewBag.Title = "Login";
    ViewBag.ShowLoginBackground = true;
    var tenantToken = ViewBag.TenantToken as string;
    var isTenantPortal = ViewBag.IsTenantPortal == true;
    var organizationName = ViewBag.OrganizationName as string;
    ViewBag.AuthPortalTitle = "Asset Management Module";
    if (isTenantPortal && !string.IsNullOrWhiteSpace(organizationName))
    {
        ViewBag.AuthPortalSubtitle = "Sign in to <strong>" + organizationName + "</strong>.";
    }
    else if (isTenantPortal)
    {
        ViewBag.AuthPortalSubtitle = "Sign in to your organization portal.";
    }
    else
    {
        ViewBag.AuthPortalSubtitle = "Platform administrator sign in. Tenant users can also sign in here, or use your organization portal.";
    }
}

<div class="am-auth-container">
    <div class="am-auth-shell">
        <div class="am-portal-panel am-auth-panel">
            @Html.Partial("_AuthPortalBrand")

            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success am-portal-alert mb-3">@TempData["Message"]</div>
            }
            @if (ViewBag.LicenseBanner != null)
            {
                <div class="alert alert-warning am-portal-alert mb-3">@ViewBag.LicenseBanner</div>
            }

            @{
                string loginAction;
                if (string.IsNullOrWhiteSpace(tenantToken))
                {
                    loginAction = Url.RouteUrl("Default", new { controller = "Account", action = "Login", returnUrl = ViewBag.ReturnUrl });
                }
                else
                {
                    loginAction = "/" + tenantToken + "/Account/Login";
                    if (ViewBag.ReturnUrl != null)
                    {
                        loginAction += "?returnUrl=" + Server.UrlEncode(ViewBag.ReturnUrl as string);
                    }
                }
            }
            <form action="@loginAction" method="post" role="form" id="loginForm" class="am-auth-form">
                @Html.AntiForgeryToken()
                @if (!string.IsNullOrWhiteSpace(tenantToken))
                {
                    <input type="hidden" name="tenantPortal" value="@tenantToken" />
                }
                @Html.ValidationSummary(true, "", new { @class = "text-danger alert alert-danger am-portal-alert py-2 mb-3" })

                <div class="mb-3">
                    @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", autocomplete = "username", placeholder = "name@example.com" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.Password, new { @class = "form-label" })
                    @Html.PasswordFieldFor(m => m.Password, new { autocomplete = "current-password" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                </div>

                <div class="form-check mb-3">
                    @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input" })
                    @Html.LabelFor(m => m.RememberMe, new { @class = "form-check-label" })
                </div>

                @if (ViewBag.LoginCaptchaEnabled == true)
                {
                    @Html.Partial("_CaptchaPartial")
                }

                <button type="submit" class="btn btn-primary w-100 py-2">Login</button>
            </form>

            <div class="am-auth-links mt-3">
                <a href="@(string.IsNullOrWhiteSpace(tenantToken) ? Url.RouteUrl("Default", new { controller = "Account", action = "ForgotPassword" }) : Url.RouteUrl("Tenant", new { tenant = tenantToken, controller = "Account", action = "ForgotPassword" }))" class="am-auth-link">Forgot password?</a>
            </div>

            @if (isTenantPortal)
            {
                <div class="am-auth-links mt-2 text-center">
                    <a href="@Url.RouteUrl("Tenant", new { tenant = tenantToken, controller = "Account", action = "Register" })" class="am-auth-link">Create an account</a>
                </div>
            }

            <div class="am-auth-legal mt-3 pt-3">
                <a href="@(string.IsNullOrWhiteSpace(tenantToken) ? Url.Action("Terms", "Home") : Url.RouteUrl("Tenant", new { tenant = tenantToken, controller = "Home", action = "Terms" }))" target="_blank" rel="noopener">Terms</a>
                <a href="@(string.IsNullOrWhiteSpace(tenantToken) ? Url.Action("Privacy", "Home") : Url.RouteUrl("Tenant", new { tenant = tenantToken, controller = "Home", action = "Privacy" }))" target="_blank" rel="noopener">Privacy</a>
            </div>
        </div>

        @if (!isTenantPortal)
        {
            <div class="am-portal-panel am-auth-footnote">
                <p class="mb-1">Platform Admin: <code class="user-select-all">superadmin@asset.local</code> / <code class="user-select-all">P@ssw0rd!</code></p>
                <p class="mb-0">
                    Tenant Portal:
                    <a href="@Url.RouteUrl("Tenant", new { tenant = "nanosoft", controller = "Account", action = "Login" })" class="am-auth-link am-auth-link--strong">/nanosoft/Account/Login</a>
                </p>
            </div>
        }
    </div>
</div>

@if (ViewBag.ShowLegalConsentModal == true)
{
    <div class="modal fade show d-block am-portal-modal-backdrop" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content am-portal-panel am-portal-panel--modal">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title am-portal-title h5 mb-0">Accept updated policies</h5>
                </div>
                @using (Html.BeginForm("ConfirmLegalConsent", "Account", new { tenant = tenantToken, returnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <div class="modal-body pt-3">
                        <p class="am-portal-copy mb-3">
                            Please review and accept the current
                            <a href="@ViewBag.LegalTermsUrl" target="_blank" rel="noopener" class="am-auth-link">Terms and Conditions</a>
                            and
                            <a href="@ViewBag.LegalPrivacyUrl" target="_blank" rel="noopener" class="am-auth-link">Privacy Policy</a>
                            to continue signing in.
                        </p>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="acceptLegalTerms" id="acceptLegalTerms" value="true" required />
                            <label class="form-check-label" for="acceptLegalTerms">I agree to the Terms and Privacy Policy</label>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="submit" class="btn btn-primary">Continue</button>
                    </div>
                }
            </div>
        </div>
    </div>
}
