@{

    ViewBag.Title = "Verify Identity";

    ViewBag.ShowLoginBackground = true;

    var tenantToken = ViewBag.TenantToken as string;



    ViewBag.AuthPortalBadge = "Two-step verification";

    ViewBag.AuthPortalTitle = "Enter verification code";

    ViewBag.AuthPortalSubtitle = "A 6-digit code was sent to <strong>" + ViewBag.EmailHint + "</strong>. Codes expire after 10 minutes.";

}



<div class="am-auth-container">

    <div class="am-auth-shell">

        <div class="am-portal-panel am-auth-panel">

            @Html.Partial("_AuthPortalBrand")

            @if (ViewBag.MfaSendError != null)

            {

                <div class="alert alert-warning am-portal-alert mb-3">@ViewBag.MfaSendError</div>

            }



            @using (Html.BeginForm("VerifyMfa", "Account", new { tenant = tenantToken }, FormMethod.Post, new { @class = "am-auth-form" }))

            {

                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "text-danger alert alert-danger am-portal-alert py-2 mb-3" })

                <div class="mb-3">

                    <label for="code" class="form-label">Verification code</label>

                    <input class="form-control text-center" id="code" name="code" type="text" maxlength="6"

                           placeholder="000000" required autocomplete="off" autofocus />

                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">Verify and sign in</button>

            }



            <div class="am-auth-links mt-3 text-center">

                <button type="button" id="btnResendMfa" class="btn btn-outline-primary btn-sm">Resend code</button>

            </div>

        </div>

    </div>

</div>



@section scripts {

    <script>

        (function () {

            var btn = document.getElementById('btnResendMfa');

            if (!btn) return;

            btn.addEventListener('click', function () {

                var token = document.querySelector('input[name="__RequestVerificationToken"]');

                var formData = new FormData();

                if (token) formData.append('__RequestVerificationToken', token.value);

                fetch('@(string.IsNullOrWhiteSpace(tenantToken) ? Url.Action("ResendMfaCode", "Account") : Url.RouteUrl("Tenant", new { tenant = tenantToken, controller = "Account", action = "ResendMfaCode" }))', {

                    method: 'POST',

                    body: formData,

                    headers: { 'X-Requested-With': 'XMLHttpRequest' }

                }).then(function (r) { return r.json(); }).then(function (data) {

                    alert(data.message || (data.success ? 'Code resent.' : 'Could not resend code.'));

                });

            });

        })();

    </script>

}

