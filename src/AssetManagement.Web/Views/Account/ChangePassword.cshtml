@model AssetManagement.Application.ViewModels.ChangePasswordViewModel
@{
    ViewBag.Title = "Change Password";
}
<h3>Change Password</h3>
<p class="text-muted">@ViewBag.PasswordPolicyMessage</p>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card card-kpi">
            <div class="card-body">
                @using (Html.BeginForm("ChangePassword", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="mb-3">
                        @Html.LabelFor(m => m.CurrentPassword, new { @class = "form-label" })
                        @Html.PasswordFieldFor(m => m.CurrentPassword, new { autocomplete = "current-password" })
                        @Html.ValidationMessageFor(m => m.CurrentPassword, "", new { @class = "text-danger small" })
                    </div>
                    <div class="mb-3">
                        @Html.LabelFor(m => m.NewPassword, new { @class = "form-label" })
                        @Html.PasswordFieldFor(m => m.NewPassword, new { autocomplete = "new-password" })
                        @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger small" })
                    </div>
                    <div class="mb-3">
                        @Html.LabelFor(m => m.ConfirmPassword, new { @class = "form-label" })
                        @Html.PasswordFieldFor(m => m.ConfirmPassword, new { autocomplete = "new-password" })
                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Update password</button>
                        <a class="btn btn-outline-secondary" href="@Url.Action("Profile", "Account")">Cancel</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
