@model AssetManagement.Web.Models.ForgotPasswordViewModel
@{
    ViewBag.Title = "Forgot Password";
    ViewBag.ShowLoginBackground = true;
    var tenantToken = ViewBag.TenantToken as string;
    var isTenantPortal = ViewBag.IsTenantPortal == true;
    var organizationName = ViewBag.OrganizationName as string;

    ViewBag.AuthPortalBadge = "Password recovery";
    ViewBag.AuthPortalTitle = "Forgot password";
    if (isTenantPortal && !string.IsNullOrWhiteSpace(organizationName))
    {
        ViewBag.AuthPortalSubtitle = "Enter your account email for <strong>" + organizationName + "</strong> to receive reset instructions.";
    }
    else if (isTenantPortal)
    {
        ViewBag.AuthPortalSubtitle = "Enter your account email to receive reset instructions for your organization portal.";
    }
    else
    {
        ViewBag.AuthPortalSubtitle = "Enter your account email to receive password reset instructions.";
    }
}

<div class="am-auth-container">
    <div class="am-auth-shell">
        <div class="am-portal-panel am-auth-panel">
            @Html.Partial("_AuthPortalBrand")

            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success am-portal-alert mb-3">@TempData["Message"]</div>
            }

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger alert alert-danger am-portal-alert py-2 mb-3" })

                <div class="mb-3">
                    @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", autocomplete = "username", placeholder = "name@example.com" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">Send reset link</button>
            }

            <div class="am-auth-links mt-3 text-center">
                <a href="@(string.IsNullOrWhiteSpace(tenantToken) ? Url.RouteUrl("Default", new { controller = "Account", action = "Login" }) : Url.RouteUrl("Tenant", new { tenant = tenantToken, controller = "Account", action = "Login" }))" class="am-auth-link">Back to login</a>
            </div>

            <div class="am-auth-legal mt-3 pt-3">
                <a href="@(string.IsNullOrWhiteSpace(tenantToken) ? Url.Action("Terms", "Home") : Url.RouteUrl("Tenant", new { tenant = tenantToken, controller = "Home", action = "Terms" }))" target="_blank" rel="noopener">Terms</a>
                <a href="@(string.IsNullOrWhiteSpace(tenantToken) ? Url.Action("Privacy", "Home") : Url.RouteUrl("Tenant", new { tenant = tenantToken, controller = "Home", action = "Privacy" }))" target="_blank" rel="noopener">Privacy</a>
            </div>
        </div>
    </div>
</div>
