@model AssetManagement.Web.Models.ResetPasswordViewModel
@{
    ViewBag.Title = "Reset Password";
}
<div class="am-auth-container row justify-content-center">
    <div class="col-sm-10 col-md-8 col-lg-6 col-xl-5 col-xxl-4">
        <div class="card am-auth-card">
            <div class="card-header">Password reset</div>
            <div class="card-body">
                <h1 class="h4 mb-2 text-primary fw-bold">Reset Password</h1>
                <p class="text-muted mb-4">Choose a new password for your account.</p>
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger alert alert-danger py-2 mb-3" })
                    @Html.HiddenFor(m => m.Code)
                    <div class="mb-3">
                        @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", autocomplete = "username", placeholder = "name@example.com" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                    </div>
                    <div class="mb-3">
                        @Html.LabelFor(m => m.Password, new { @class = "form-label" })
                        @Html.PasswordFieldFor(m => m.Password, new { autocomplete = "new-password" })
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                    </div>
                    <div class="mb-3">
                        @Html.LabelFor(m => m.ConfirmPassword, new { @class = "form-label" })
                        @Html.PasswordFieldFor(m => m.ConfirmPassword, new { autocomplete = "new-password" })
                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 py-2">Reset Password</button>
                        <a class="btn btn-outline-secondary px-3 py-2" href="@Url.RouteUrl("Default", new { controller = "Account", action = "Login" })">Back to Login</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
