@using AssetManagement.Application.Security
@{
    ViewBag.Title = "Privacy Policy";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var companyName = ViewBag.CompanyName as string ?? LegalPolicyDefaults.CompanyName;
    var contactEmail = ViewBag.ContactEmail as string ?? LegalPolicyDefaults.ContactEmail;
    var contactAddress = ViewBag.ContactAddress as string ?? LegalPolicyDefaults.ContactAddress;
    var lastUpdated = ViewBag.LastUpdated as string ?? LegalPolicyDefaults.LastUpdated;
    var legalTenant = ViewBag.LegalDocTenant as string;
    var legalPage = ViewBag.LegalDocPage as string ?? "privacy";
    var rel = ViewBag.LegalRelationship is LegalRelationshipKind
        ? (LegalRelationshipKind)ViewBag.LegalRelationship
        : LegalRelationshipKind.TenantUser;
}

<div class="container py-4">
    <div class="card am-auth-card">
        <div class="card-body p-4 p-md-5">
            <nav class="mb-4 pb-3 border-bottom" aria-label="Legal documents">
                <a class="btn btn-sm me-2 @(legalPage == "privacy" ? "btn-primary" : "btn-outline-primary")"
                   href="@(string.IsNullOrWhiteSpace(legalTenant) ? Url.Action("Privacy", "Home") : Url.RouteUrl("Tenant", new { tenant = legalTenant, controller = "Home", action = "Privacy" }))">Privacy policy</a>
                <a class="btn btn-sm @(legalPage == "terms" ? "btn-primary" : "btn-outline-primary")"
                   href="@(string.IsNullOrWhiteSpace(legalTenant) ? Url.Action("Terms", "Home") : Url.RouteUrl("Tenant", new { tenant = legalTenant, controller = "Home", action = "Terms" }))">Terms and conditions</a>
            </nav>

            <h2 class="mb-2">Privacy Policy</h2>
            <p class="text-muted small mb-4">Policy version: <strong>@(ViewBag.PrivacyVersionLabel as string)</strong> · Last updated: @lastUpdated</p>

            @if (rel == LegalRelationshipKind.PlatformAdmin)
            {
                <p class="text-muted mb-4">
                    This Privacy Policy explains how @companyName collects and uses information when you operate the Asset Management platform
                    <strong>as a platform administrator</strong> managing organizations, licenses, and tenant access.
                </p>
            }
            else if (rel == LegalRelationshipKind.CompanyAdmin)
            {
                <p class="text-muted mb-4">
                    This Privacy Policy explains how @companyName and your organization process information when you use the Asset Management module
                    <strong>as a company administrator</strong> managing users, assets, and organizational settings.
                </p>
            }
            else
            {
                <p class="text-muted mb-4">
                    This Privacy Policy explains how @companyName and your employer organization collect and use information when you use the Asset Management module
                    <strong>as a tenant user</strong> performing asset, custody, and workflow tasks.
                </p>
            }

            <h5>1. Information We Collect</h5>
            <ul>
                <li>Account identifiers (name, email, employee number, role, department).</li>
                <li>Asset and workflow data you create or update within your organization.</li>
                <li>Security events such as login attempts, MFA challenges, and audit records.</li>
                <li>Technical data including IP address, browser details, and session cookies.</li>
            </ul>

            <h5>2. How We Use Information</h5>
            <ul>
                <li>To provide asset management, approvals, custody, and reporting features.</li>
                <li>To secure accounts with authentication, MFA, and access controls.</li>
                <li>To maintain audit trails required for operational and compliance needs.</li>
                <li>To comply with law and enforce platform policies.</li>
            </ul>

            <h5>3. Data Sharing</h5>
            <p>
                Information is shared within your organization according to role permissions.
                @companyName may process data as the platform operator hosting the service.
                Data may also be disclosed when required by law.
            </p>

            <h5>4. Data Security and Retention</h5>
            <p>
                We apply reasonable administrative and technical safeguards.
                Records are retained according to organizational policy and legal requirements.
            </p>

            <h5>5. Contact</h5>
            <p class="mb-0">
                Questions about this policy: <a href="mailto:@contactEmail">@contactEmail</a> · @contactAddress
            </p>
        </div>
    </div>
</div>
