@model IEnumerable<AssetManagement.Application.ViewModels.AssetListVm>
@using AssetManagement.Domain.Enums
@using AssetManagement.Web.Helpers
@{
    ViewBag.Title = "Assets";
    var canCreateAsset = Html.HasPermission("Assets.Create");
    var canEditAsset = Html.HasPermission("Assets.Edit");
}
@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "Asset Register",
    Subtitle = "Search, review, and act on every tracked asset from one place.",
    PrimaryActionUrl = canCreateAsset ? Url.Action("Create") : null,
    PrimaryActionLabel = canCreateAsset ? "Create Asset" : null
})

<form class="row g-2 mb-3" method="get">
    <div class="col-md-5">
        <input type="text" class="form-control" name="Search" placeholder="Search by asset tag, name or serial" value="@Request.QueryString["Search"]" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary">Filter</button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="card card-kpi">
        <div class="card-body am-empty-state">
            <h5>No assets yet</h5>
            <p class="text-muted mb-3">Start by creating your first asset record, then use the asset profile to assign it, transfer it, or track maintenance.</p>
            @if (canCreateAsset)
            {
                <a class="btn btn-primary" href="@Url.Action("Create")">Create Asset</a>
            }
        </div>
    </div>
}
else
{
    <div class="card card-kpi">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Asset Tag</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Department</th>
                            <th>Status</th>
                            <th>Current Book Value</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        var badge = item.CurrentStatus == AssetStatus.Assigned ? "success" :
                                    item.CurrentStatus == AssetStatus.UnderMaintenance ? "warning" :
                                    item.CurrentStatus == AssetStatus.Lost || item.CurrentStatus == AssetStatus.Stolen ? "danger" : "secondary";
                        <tr>
                            <td>@item.AssetTag</td>
                            <td>@item.AssetName</td>
                            <td>@item.CategoryName</td>
                            <td>@item.DepartmentName</td>
                            <td><span class="badge bg-@badge badge-status">@item.CurrentStatus</span></td>
                            <td>@item.CurrentBookValue.ToString("N2")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", new { id = item.Id })">Details</a>
                                @if (canEditAsset)
                                {
                                    <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Edit", new { id = item.Id })">Edit</a>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
