@model AssetManagement.Web.ViewModels.ListPageViewModel<AssetManagement.Application.ViewModels.AssetListVm>
@using AssetManagement.Domain.Enums
@using AssetManagement.Web.Helpers
@{
    ViewBag.Title = ViewBag.ListTitle as string ?? "Assets";
    var canEditAsset = Html.HasPermission("Assets.Edit");
    var canCreateIncident = Html.HasPermission("Incidents.Create");
    var isMyAssets = string.Equals(ViewBag.ListTitle as string, "My Assets", System.StringComparison.OrdinalIgnoreCase);
    var returnUrl = Url.Action(isMyAssets ? "MyAssets" : "DepartmentAssets", "Assets");
    var currentSort = ViewBag.Sort as string;
    var currentDirection = ViewBag.Direction as string;
}
@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = ViewBag.ListTitle as string ?? "Assets",
    Subtitle = ViewBag.ListSubtitle as string ?? "Tagged assets in your custody scope.",
    BackUrl = Url.Action("Index"),
    BackLabel = "All assets"
})

<form class="am-list-toolbar" method="get">
    <div class="row g-2 align-items-end">
        <div class="col-md-5">
            <input type="text" class="form-control" name="Search" placeholder="Filter by asset tag (primary), name, or serial" value="@Model.Search" data-am-table-filter />
        </div>
        <div class="col-md-2">
            <select class="form-select" name="pageSize">
                @foreach (var size in new[] { 10, 25, 50 })
                {
                    <option value="@size" selected="@(Model.PageSize == size)">@size per page</option>
                }
            </select>
        </div>
        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-outline-primary">Apply</button>
        </div>
    </div>
</form>

@if (!Model.Items.Any())
{
    <div class="card card-kpi am-fade-in">
        <div class="card-body am-empty-state">
            <h5>No assets in this view</h5>
            <p class="text-muted mb-0">Nothing is assigned or registered under the current custody filter.</p>
        </div>
    </div>
}
else
{
    <div class="card card-kpi am-fade-in">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0 am-filterable-table" data-am-filterable>
                    <thead class="table-light">
                        <tr>
                            <th>@Html.SortLink("Asset Tag", "tag", currentSort, currentDirection)</th>
                            <th>@Html.SortLink("Name", "name", currentSort, currentDirection)</th>
                            <th>@Html.SortLink("Department", "department", currentSort, currentDirection)</th>
                            <th>Custodian</th>
                            <th>@Html.SortLink("Status", "status", currentSort, currentDirection)</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td><span class="am-tag-pill">@item.AssetTag</span></td>
                            <td>@item.AssetName</td>
                            <td>@item.DepartmentName</td>
                            <td>@(string.IsNullOrWhiteSpace(item.CurrentCustodianName) ? DisplayText.Empty : item.CurrentCustodianName)</td>
                            <td><span class="badge bg-@StatusHtmlHelpers.ToBadgeClass(item.CurrentStatus) badge-status">@item.CurrentStatus</span></td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", new { id = item.Id })">Details</a>
                                @if (isMyAssets && item.CurrentStatus == AssetStatus.Assigned)
                                {
                                    if (canCreateIncident)
                                    {
                                        <a class="btn btn-sm btn-outline-warning" href="@Url.Action("Create", "Incidents", new { assetId = item.Id })">Report issue</a>
                                    }
                                    using (Html.BeginForm("AcknowledgeReceipt", "Custodian", FormMethod.Post, new { @class = "d-inline" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="assetId" value="@item.Id" />
                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Acknowledge</button>
                                    }
                                    using (Html.BeginForm("RequestReturn", "Custodian", FormMethod.Post, new { @class = "d-inline" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="assetId" value="@item.Id" />
                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                        <input type="hidden" name="notes" value="Custodian requested return from My Assets." />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">Request return</button>
                                    }
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    @Html.Partial("_Pagination", new AssetManagement.Web.ViewModels.PaginationViewModel
    {
        Page = Model.Page,
        TotalPages = Model.TotalPages,
        TotalCount = Model.TotalCount,
        StartItem = Model.StartItem,
        EndItem = Model.EndItem
    })
}
