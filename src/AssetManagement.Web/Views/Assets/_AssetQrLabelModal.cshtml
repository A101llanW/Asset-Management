@model AssetManagement.Web.ViewModels.AssetLabelPrintVm
<div class="modal fade" id="assetQrLabelModal" tabindex="-1" aria-labelledby="assetQrLabelModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="assetQrLabelModalTitle">Asset QR label</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="am-asset-label-sheet am-asset-label-sheet--modal">
                    @Html.Partial("_AssetLabelContent", Model)
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-am-asset-label-print="true">Print label</button>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
