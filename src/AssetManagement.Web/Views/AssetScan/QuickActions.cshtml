@model AssetManagement.Application.ViewModels.AssetQuickActionsVm
@using AssetManagement.Application.Services
@using AssetManagement.Domain.Enums
@{
    ViewBag.Title = "Quick Actions";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = Model.AssetName,
    Subtitle = Model.AssetTag + " · " + Model.DepartmentName,
    BackUrl = Url.Action("Lookup", "AssetScan"),
    BackLabel = "Scan again"
})

<div class="am-quick-actions">

    @* Asset Identity Card *@
    <div class="am-qa-identity card card-kpi border-0 mb-4">
        <div class="card-body p-4">
            <div class="d-flex align-items-center gap-3">
                <div class="am-qa-identity-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                </div>
                <div class="flex-grow-1 min-width-0">
                    <div class="am-tag-pill am-tag-pill--sm mb-1">@Model.AssetTag</div>
                    <h4 class="fw-bold mb-1 text-truncate">@Model.AssetName</h4>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span class="text-muted small">@Model.DepartmentName</span>
                        <span class="badge bg-light text-secondary border">@Model.CurrentStatus</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Action Grid *@
    <div class="am-qa-grid row g-3">
        @if (Model.CanAssign)
        {
            <div class="col-6">
                <a class="am-qa-tile am-qa-tile--primary text-decoration-none"
                   href="@Url.Action("Create", "Assignments", new { assetId = Model.AssetId, returnUrl = Url.Action("QuickActions", "AssetScan", new { id = Model.AssetId }) })">
                    <div class="am-qa-tile-icon am-qa-tile-icon--primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                    </div>
                    <span class="am-qa-tile-label">Assign</span>
                    <span class="am-qa-tile-hint">Allocate to user</span>
                </a>
            </div>
        }
        else if (Html.HasPermission("Assets.Assign") && Model.CurrentStatus == AssetStatus.Assigned)
        {
            <div class="col-12">
                <div class="alert alert-light border mb-0 small" role="status">
                    @AssetCustodyRules.AlreadyAssignedMessage
                </div>
            </div>
        }
        @if (Model.CanTransfer)
        {
            <div class="col-6">
                <a class="am-qa-tile am-qa-tile--warning text-decoration-none"
                   href="@Url.Action("Create", "Transfers", new { assetId = Model.AssetId, returnUrl = Url.Action("QuickActions", "AssetScan", new { id = Model.AssetId }) })">
                    <div class="am-qa-tile-icon am-qa-tile-icon--warning">
                        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
                    </div>
                    <span class="am-qa-tile-label">Transfer</span>
                    <span class="am-qa-tile-hint">Change custody</span>
                </a>
            </div>
        }
        @if (Model.CanReturn)
        {
            <div class="col-6">
                <a class="am-qa-tile am-qa-tile--success text-decoration-none"
                   href="@Url.Action("Create", "Returns", new { assetId = Model.AssetId, returnUrl = Url.Action("QuickActions", "AssetScan", new { id = Model.AssetId }) })">
                    <div class="am-qa-tile-icon am-qa-tile-icon--success">
                        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 14 4 9 9 4"/><path d="M20 20v-7a4 4 0 0 0-4-4H4"/></svg>
                    </div>
                    <span class="am-qa-tile-label">Return</span>
                    <span class="am-qa-tile-hint">Check asset back in</span>
                </a>
            </div>
        }
        @if (Model.CanReportIncident)
        {
            <div class="col-6">
                <a class="am-qa-tile am-qa-tile--danger text-decoration-none"
                   href="@Url.Action("Create", "Incidents", new { assetId = Model.AssetId, returnUrl = Url.Action("QuickActions", "AssetScan", new { id = Model.AssetId }) })">
                    <div class="am-qa-tile-icon am-qa-tile-icon--danger">
                        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    </div>
                    <span class="am-qa-tile-label">Incident</span>
                    <span class="am-qa-tile-hint">Report damage/loss</span>
                </a>
            </div>
        }
    </div>

    <div class="mt-4">
        <a class="btn btn-outline-secondary w-100 py-2" href="@Url.Action("Details", "Assets", new { id = Model.AssetId })">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.4rem;vertical-align:-2px;" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            View full asset profile
        </a>
    </div>

</div>
