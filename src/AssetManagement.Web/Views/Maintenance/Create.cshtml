@model AssetManagement.Application.ViewModels.AssetMaintenanceVm
@{
    ViewBag.Title = "Maintenance";
    var assetContext = ViewBag.AssetContext as AssetManagement.Web.ViewModels.AssetWorkflowContextViewModel;
}

@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "Create Maintenance Ticket",
    Subtitle = "Open a maintenance record with the current asset context so support teams can act quickly.",
    BackUrl = Url.Action("Details", "Assets", new { id = Model.AssetId }),
    BackLabel = "Back to Asset"
})

@Html.Partial("_AssetWorkflowContext", assetContext)

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })
    @Html.HiddenFor(m => m.AssetId)
    <div class="mb-3">
        <label class="form-label">Maintenance Type</label>
        @Html.DropDownListFor(m => m.MaintenanceType, (SelectList)ViewBag.MaintenanceTypes, "-- Select Type --", new { @class = "form-select" })
        @Html.ValidationMessageFor(m => m.MaintenanceType, "", new { @class = "text-danger" })
    </div>
    <div class="mb-3">
        <label class="form-label">Reported Issue</label>
        @Html.TextAreaFor(m => m.ReportedIssue, new { @class = "form-control", rows = "3" })
        @Html.ValidationMessageFor(m => m.ReportedIssue, "", new { @class = "text-danger" })
    </div>
    @Html.Partial("_FormActions", new AssetManagement.Web.ViewModels.FormActionsViewModel
    {
        SubmitLabel = "Create Ticket",
        BackUrl = Url.Action("Details", "Assets", new { id = Model.AssetId }),
        BackLabel = "Back to Asset"
    })
}
