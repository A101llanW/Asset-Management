@model AssetManagement.Web.ViewModels.ListPageViewModel<AssetManagement.Application.ViewModels.AssignmentListVm>
@using AssetManagement.Web.Helpers
@{
    ViewBag.Title = "Assignments";
    var departments = ViewBag.Departments as System.Web.Mvc.SelectList;
    var currentSort = ViewBag.Sort as string;
    var currentDirection = ViewBag.Direction as string;
}
@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "Assignments",
    Subtitle = "Search and review custody handovers across the organization.",
    BackUrl = Url.Action("Index", "Assets"),
    BackLabel = "Assets"
})

@* Filter Toolbar *@
<div class="card card-kpi border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form class="am-list-toolbar mb-0" method="get">
            <div class="row g-2 align-items-center">
                <div class="col-md-4">
                    <input type="text" class="form-control" name="Search" placeholder="Asset tag, name, or assignee..." value="@Model.Search" />
                </div>
                <div class="col-md-3">
                    @Html.DropDownList("DepartmentId", departments, "All departments", new { @class = "form-select" })
                </div>
                <div class="col-md-2">
                    <select class="form-select" name="ActiveOnly">
                        <option value="">All records</option>
                        <option value="true" selected="@(Request["ActiveOnly"] == "true")">Current custody only</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <select class="form-select" name="pageSize">
                        @foreach (var size in new[] { 10, 25, 50 })
                        {
                            <option value="@size" selected="@(Model.PageSize == size)">@size</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary">Apply</button>
                </div>
            </div>
        </form>
    </div>
</div>

@* Table *@
<div class="card card-kpi border-0 shadow-sm am-fade-in mb-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr class="bg-light" style="font-size:0.82rem;letter-spacing:0.04em;">
                        <th class="ps-3">@Html.SortLink("Date", "date", currentSort, currentDirection)</th>
                        <th>@Html.SortLink("Asset", "asset", currentSort, currentDirection)</th>
                        <th>@Html.SortLink("Assignee", "user", currentSort, currentDirection)</th>
                        <th>@Html.SortLink("Department", "department", currentSort, currentDirection)</th>
                        <th>@Html.SortLink("Type", "type", currentSort, currentDirection)</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Items.Any())
                {
                    foreach (var item in Model.Items)
                    {
                        <tr class="border-bottom border-light">
                            <td class="ps-3 text-muted small">@item.AssignedDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                <span class="am-tag-pill am-tag-pill--sm">@item.AssetTag</span>
                                <div class="fw-semibold text-dark small mt-1">@item.AssetName</div>
                            </td>
                            <td class="text-muted small">@(string.IsNullOrWhiteSpace(item.ToUserName) ? DisplayText.Empty : item.ToUserName)</td>
                            <td class="text-muted small">@(string.IsNullOrWhiteSpace(item.ToDepartmentName) ? DisplayText.Empty : item.ToDepartmentName)</td>
                            <td>
                                <span class="badge rounded-pill" style="background:hsla(200,85%,52%,.10);color:var(--am-primary-strong);font-weight:600;font-size:.78rem;">@item.AssignmentType</span>
                            </td>
                            <td class="text-end pe-3">
                                <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", "Assets", new { id = item.AssetId })">Asset</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="py-5 text-center">
                            <div class="text-muted mb-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/><line x1="16" y1="11" x2="21" y2="16"/></svg>
                            </div>
                            <div class="fw-semibold text-dark">No assignments found</div>
                            <p class="text-muted small mb-0">Try adjusting the filters or search term.</p>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@Html.Partial("_Pagination", new AssetManagement.Web.ViewModels.PaginationViewModel
{
    Page = Model.Page,
    TotalPages = Model.TotalPages,
    TotalCount = Model.TotalCount,
    StartItem = Model.StartItem,
    EndItem = Model.EndItem
})
