@model AssetManagement.Application.ViewModels.DashboardVm
@using AssetManagement.Web.Helpers
@{
    ViewBag.Title = "Dashboard";
    var canViewAssets = Html.HasPermission("Assets.View");
    var canRequest = Html.HasPermission("Assets.Request");
    var maxTrend = Model.AssignmentsPerMonth == null || !Model.AssignmentsPerMonth.Any()
        ? 1
        : System.Math.Max(1, Model.AssignmentsPerMonth.Max(x => x.Count));
    var deptScopeHint = Model.IsDepartmentScoped ? "Based on your visible assets." : null;
}
<div class="am-dashboard">
    <section class="am-dashboard-hero" aria-label="Operations dashboard overview">
        @Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
        {
            Title = "Operations Dashboard",
            Subtitle = "Custody snapshot with assignment trends, available inventory, and department value."
        })

        <div class="am-dashboard-kpi-grid" role="list" aria-label="Key metrics">
            <!-- Total Assets -->
            <div class="card card-kpi am-kpi-card am-dashboard-kpi am-dashboard-kpi--assets am-fade-in-safe border-top border-primary border-4" role="listitem">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="am-kpi-label text-muted">Total Assets</div>
                        <div class="am-kpi-value h2 mb-0 text-dark fw-bold">@Model.TotalAssets</div>
                    </div>
                    <div class="text-primary bg-light p-3 rounded-circle">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-package"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"></line><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                    </div>
                </div>
            </div>

            <!-- Assigned Assets -->
            <div class="card card-kpi am-kpi-card am-dashboard-kpi am-dashboard-kpi--assigned am-fade-in-safe border-top border-success border-4" role="listitem">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="am-kpi-label text-muted">Assigned</div>
                        <div class="am-kpi-value h2 mb-0 text-success fw-bold">@Model.AssignedAssets</div>
                    </div>
                    <div class="text-success bg-light p-3 rounded-circle">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-user-check"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><polyline points="17 11 19 13 23 9"></polyline></svg>
                    </div>
                </div>
            </div>

            <!-- Available inventory -->
            <a class="card card-kpi am-kpi-card am-dashboard-kpi am-dashboard-kpi--instore am-fade-in-safe border-top border-secondary border-4 text-decoration-none" role="listitem" href="@Url.Action("Index", "Assets")">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="am-kpi-label text-muted">Available</div>
                        <div class="am-kpi-value h2 mb-0 fw-bold">@Model.UnassignedAssets</div>
                        <div class="small text-muted" style="font-size: 0.72rem;">In store or returned</div>
                    </div>
                    <div class="text-secondary bg-light p-3 rounded-circle">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-inbox"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"></polyline><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"></path></svg>
                    </div>
                </div>
            </a>

            <!-- Under Maintenance -->
            <div class="card card-kpi am-kpi-card am-dashboard-kpi am-dashboard-kpi--maintenance am-fade-in-safe border-top border-info border-4" role="listitem">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="am-kpi-label text-muted">Under Maintenance</div>
                        <div class="am-kpi-value h2 mb-0 text-info fw-bold">@Model.AssetsUnderMaintenance</div>
                    </div>
                    <div class="text-info bg-light p-3 rounded-circle">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-tool"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="row g-4 mb-4">
        <!-- Monthly Assignment Trends -->
        <div class="col-lg-7">
            <div class="card card-kpi am-fade-in h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="text-uppercase fw-bold text-muted mb-3" style="font-size: 0.78rem; letter-spacing: 0.08em;">Assignments per month</h6>
                    @if (Model.AssignmentsPerMonth == null || !Model.AssignmentsPerMonth.Any())
                    {
                        <div class="py-4 text-center">
                            <p class="text-muted mb-0">No assignment activity in the last six months.</p>
                        </div>
                    }
                    else
                    {
                        <div class="am-trend-chart pt-3">
                            @foreach (var point in Model.AssignmentsPerMonth)
                            {
                                var height = (int)System.Math.Round((double)point.Count / maxTrend * 100);
                                <div class="am-trend-bar" title="@point.Label: @point.Count">
                                    <div class="am-trend-bar-fill rounded-3" style="height: @(System.Math.Max(height, 4))%; background: linear-gradient(180deg, var(--am-primary), var(--am-primary-strong));"></div>
                                    <span class="am-trend-bar-label fw-bold text-secondary">@point.Label</span>
                                    <span class="am-trend-bar-value badge bg-light text-dark fw-bold rounded-pill">@point.Count</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Top Departments by Book Value -->
        <div class="col-lg-5">
            <div class="card card-kpi am-fade-in h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="text-uppercase fw-bold text-muted mb-2" style="font-size: 0.78rem; letter-spacing: 0.08em;">Top departments by acquisition value</h6>
                    @if (!string.IsNullOrWhiteSpace(deptScopeHint))
                    {
                        <p class="small text-muted mb-3">@deptScopeHint</p>
                    }
                    @if (Model.TopDepartmentValues == null || !Model.TopDepartmentValues.Any())
                    {
                        <div class="py-4 text-center">
                            <p class="text-muted mb-0">No department breakdown available.</p>
                        </div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush mt-2">
                            @foreach (var dept in Model.TopDepartmentValues)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3 border-bottom border-light">
                                    <span>
                                        <span class="fw-bold text-dark">@dept.DepartmentName</span> 
                                        <span class="badge bg-light text-muted ms-2 rounded-pill">@dept.AssetCount assets</span>
                                    </span>
                                    <strong class="text-primary">@Html.FormatCurrency(dept.BookValue, 0)</strong>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Analytical Details Grid -->
    <div class="row g-4 mb-4">
        <!-- Financial Summary -->
        <div class="col-md-6">
            <div class="card card-kpi am-fade-in border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="text-uppercase fw-bold text-muted mb-3" style="font-size: 0.78rem; letter-spacing: 0.08em;">Financial Summary</h6>
                    <div class="d-flex justify-content-between py-2 border-bottom border-light">
                        <span class="text-muted">Acquisition Value</span>
                        <strong class="text-dark">@Html.FormatCurrency(Model.TotalAcquisitionValue)</strong>
                    </div>
                    <div class="d-flex justify-content-between py-2">
                        <span class="text-muted">Total TCO (Scoped)</span>
                        <strong class="text-primary">@Html.FormatCurrency(Model.TotalCostOfOwnership)</strong>
                    </div>
                </div>
            </div>
        </div>

        <!-- Alert Center -->
        <div class="col-md-6">
            <div class="card card-kpi am-fade-in border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="text-uppercase fw-bold text-muted mb-3" style="font-size: 0.78rem; letter-spacing: 0.08em;">Alert Center</h6>
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-light">
                        <span class="text-muted">Warranty Expiries (@Model.WarrantyThresholdDays Days)</span>
                        @if (Model.ExpiringWarrantyCount > 0)
                        {
                            <span class="badge bg-danger rounded-pill">@Model.ExpiringWarrantyCount active</span>
                        }
                        else
                        {
                            <span class="badge bg-light text-muted rounded-pill">0 alerts</span>
                        }
                    </div>
                    <div class="d-flex justify-content-between align-items-center py-2">
                        <span class="text-muted">Insurance Expiries (@Model.InsuranceThresholdDays Days)</span>
                        @if (Model.ExpiringInsuranceCount > 0)
                        {
                            <span class="badge bg-warning text-dark rounded-pill">@Model.ExpiringInsuranceCount active</span>
                        }
                        else
                        {
                            <span class="badge bg-light text-muted rounded-pill">0 alerts</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Navigation Hub -->
    @if (canViewAssets)
    {
        <div class="card card-kpi am-fade-in border-0 shadow-sm">
            <div class="card-body p-4">
                <h6 class="text-uppercase fw-bold text-muted mb-3" style="font-size: 0.78rem; letter-spacing: 0.08em;">Operational Navigation Hub</h6>
                <div class="d-flex flex-wrap gap-2 pt-1">
                    <a class="btn btn-primary d-flex align-items-center gap-2" href="@TenantUrlHelper.TenantRouteUrl(Url, "Lookup", "AssetScan")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-maximize"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path></svg>
                        Scan Asset
                    </a>
                    <a class="btn btn-outline-primary" href="@Url.Action("Index", "Assets")">Asset Register</a>
                    <a class="btn btn-outline-primary" href="@Url.Action("MyAssets", "Assets")">My Assets</a>
                    <a class="btn btn-outline-primary" href="@Url.Action("Index", "Search")">Global Search</a>
                    <a class="btn btn-outline-primary" href="@Url.Action("List", "Assignments")">Assignments</a>
                    <a class="btn btn-outline-secondary" href="@Url.Action("Index", "PendingApprovals")">Pending Approvals (@Model.ApprovalBacklogCount)</a>
                    @if (canRequest)
                    {
                        <a class="btn btn-outline-success" href="@Url.Action("Create", "AssetRequests")">Request an Asset</a>
                    }
                </div>
            </div>
        </div>
    }
</div>
