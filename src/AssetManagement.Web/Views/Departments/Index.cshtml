@model AssetManagement.Web.ViewModels.ListPageViewModel<AssetManagement.Application.ViewModels.DepartmentVm>
@using AssetManagement.Web.Helpers
@{
    ViewBag.Title = "Departments";
    var canCreateDepartment = Html.HasPermission("Departments.Create");
    var canEditDepartment = Html.HasPermission("Departments.Edit");
    var currentSort = ViewBag.Sort as string;
    var currentDirection = ViewBag.Direction as string;
    var statusFilter = ViewBag.StatusFilter as string ?? "active";
    var statusLabel = statusFilter == "all" ? "departments" : statusFilter == "inactive" ? "inactive departments" : "active departments";
}
@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "Departments",
    Subtitle = "Maintain the business units that own and receive assets. Showing " + statusLabel + ".",
    PrimaryActionUrl = canCreateDepartment ? Url.Action("Create") : null,
    PrimaryActionLabel = canCreateDepartment ? "Create Department" : null
})
<form class="am-list-toolbar" method="get">
    <div class="row g-2">
        <div class="col-md-5">
            <input type="text" class="form-control" name="search" placeholder="Search by code, name, or description" value="@Model.Search" />
        </div>
        <div class="col-md-3">
            <select class="form-select" name="status">
                <option value="active" selected="@(statusFilter == "active")">Active only</option>
                <option value="inactive" selected="@(statusFilter == "inactive")">Inactive only</option>
                <option value="all" selected="@(statusFilter == "all")">All statuses</option>
            </select>
        </div>
        <div class="col-md-2">
            <select class="form-select" name="pageSize">
                @foreach (var size in new[] { 10, 25, 50 })
                {
                    <option value="@size" selected="@(Model.PageSize == size)">@size per page</option>
                }
            </select>
        </div>
        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-outline-primary">Apply</button>
        </div>
    </div>
</form>
@if (!Model.Items.Any())
{
    <div class="card card-kpi">
        <div class="card-body am-empty-state">
            <h5>No departments yet</h5>
            <p class="text-muted mb-3">Create departments before assigning assets so ownership and reporting stay accurate.</p>
            @if (canCreateDepartment)
            {
                <a class="btn btn-primary" href="@Url.Action("Create")">Create Department</a>
            }
        </div>
    </div>
}
else
{
    <div class="card card-kpi">
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead class="table-light"><tr><th>@Html.SortLink("Code", "code", currentSort, currentDirection)</th><th>@Html.SortLink("Name", "name", currentSort, currentDirection)</th><th>Description</th><th>@Html.SortLink("Status", "status", currentSort, currentDirection)</th><th></th></tr></thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Code</td>
                        <td>@item.Name</td>
                        <td>@item.Description</td>
                        <td><span class="badge bg-@StatusHtmlHelpers.ToBadgeClass(item.IsActive) badge-status">@(item.IsActive ? "Active" : "Inactive")</span></td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", new { id = item.Id, returnUrl = Request.RawUrl })">Details</a>
                            @if (canEditDepartment)
                            {
                                <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Edit", new { id = item.Id, returnUrl = Request.RawUrl })">Edit</a>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    @Html.Partial("_Pagination", new AssetManagement.Web.ViewModels.PaginationViewModel { Page = Model.Page, TotalPages = Model.TotalPages, TotalCount = Model.TotalCount, StartItem = Model.StartItem, EndItem = Model.EndItem })
    <p class="small text-muted mt-2 mb-0">Showing @Model.StartItem-@Model.EndItem of @Model.TotalCount @statusLabel.</p>
}
