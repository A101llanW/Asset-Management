@model AssetManagement.Application.ViewModels.DepartmentVm
@{
    ViewBag.Title = "Edit Department";
    var returnUrl = ViewBag.ReturnUrl as string ?? Url.Action("Details", new { id = Model.Id });
}
@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "Edit Department",
    Subtitle = "Update the department details used across users, assignments, and reporting.",
    BackUrl = returnUrl,
    BackLabel = "Back",
    Breadcrumbs = new[]
    {
        new AssetManagement.Web.ViewModels.BreadcrumbItemViewModel { Label = "Departments", Url = Url.Action("Index") },
        new AssetManagement.Web.ViewModels.BreadcrumbItemViewModel { Label = Model.Name, Url = Url.Action("Details", new { id = Model.Id, returnUrl = Url.Action("Index") }) },
        new AssetManagement.Web.ViewModels.BreadcrumbItemViewModel { Label = "Edit Department" }
    }
})
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Id)
    <input type="hidden" name="returnUrl" value="@returnUrl" />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    <div class="mb-3">
        @Html.LabelFor(m => m.Name, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
    </div>
    <div class="mb-3">
        @Html.LabelFor(m => m.Code, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Code, new { @class = "form-control" })
    </div>
    <div class="mb-3">
        @Html.LabelFor(m => m.Description, new { @class = "form-label" })
        @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = "3" })
    </div>
    <div class="form-check mb-3">
        @Html.CheckBoxFor(m => m.IsActive, new { @class = "form-check-input" })
        @Html.LabelFor(m => m.IsActive, new { @class = "form-check-label" })
    </div>
    @Html.Partial("_FormActions", new AssetManagement.Web.ViewModels.FormActionsViewModel
    {
        SubmitLabel = "Update Department",
        BackUrl = returnUrl,
        BackLabel = "Back"
    })
}
