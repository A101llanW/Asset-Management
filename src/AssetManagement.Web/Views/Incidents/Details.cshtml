@model AssetManagement.Application.ViewModels.IncidentDetailsVm
@{
    ViewBag.Title = "Incident " + Model.IncidentNumber;
    var canEdit = ViewBag.CanEdit == true;
}
@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "Incident " + Model.IncidentNumber,
    Subtitle = Model.IncidentType + " - " + Model.Severity,
    BackUrl = Url.Action("Index"),
    BackLabel = "Back to Incidents",
    PrimaryActionUrl = Url.Action("Details", "Assets", new { id = Model.AssetId }),
    PrimaryActionLabel = "View Asset"
})
<div class="card card-kpi am-fade-in">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Asset</dt><dd class="col-sm-9"><a href="@Url.Action("Details", "Assets", new { id = Model.AssetId })">@Model.AssetTag - @Model.AssetName</a></dd>
            <dt class="col-sm-3">Type</dt><dd class="col-sm-9">@Model.IncidentType</dd>
            <dt class="col-sm-3">Severity</dt><dd class="col-sm-9">@Model.Severity</dd>
            <dt class="col-sm-3">Date</dt><dd class="col-sm-9">@Model.IncidentDate.ToString("yyyy-MM-dd HH:mm") UTC</dd>
            <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.ResolutionStatus</dd>
            <dt class="col-sm-3">Description</dt><dd class="col-sm-9">@Model.Description</dd>
            @if (!string.IsNullOrWhiteSpace(Model.WitnessComments))
            {
                <dt class="col-sm-3">Witness comments</dt><dd class="col-sm-9">@Model.WitnessComments</dd>
            }
            @if (!string.IsNullOrWhiteSpace(Model.PoliceCaseReference))
            {
                <dt class="col-sm-3">Police reference</dt><dd class="col-sm-9">@Model.PoliceCaseReference</dd>
            }
            @if (!string.IsNullOrWhiteSpace(Model.LiabilityNotes))
            {
                <dt class="col-sm-3">Liability notes</dt><dd class="col-sm-9">@Model.LiabilityNotes</dd>
            }
            <dt class="col-sm-3">Reported</dt><dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</dd>
        </dl>
        @if (canEdit)
        {
            <hr />
            using (Html.BeginForm("UpdateStatus", "Incidents", FormMethod.Post, new { @class = "row g-2" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="col-md-4">
                    <label class="form-label" for="resolutionStatus">Resolution status</label>
                    @Html.DropDownList("resolutionStatus", (SelectList)ViewBag.ResolutionStatuses, new { @class = "form-select", id = "resolutionStatus", required = "required" })
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary">Update status</button>
                </div>
            }
            <p class="text-muted small mb-0 mt-2">Closing an incident requires all linked claims to be settled or rejected. Written off retires the asset unless it is lost or stolen.</p>
        }
    </div>
</div>
