@model AssetManagement.Web.ViewModels.AssetTypeVm
@{
    ViewBag.Title = "Create Asset Type";
    var returnUrl = ViewBag.ReturnUrl as string ?? Url.Action("Index");
    var categories = ViewBag.Categories as SelectList;
    ViewData["UsefulLifeFormMode"] = "type";
}
@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "Create Asset Type",
    Subtitle = "Add a type under a category so users can choose the correct asset classification.",
    BackUrl = returnUrl,
    BackLabel = "Back",
    Breadcrumbs = new[]
    {
        new AssetManagement.Web.ViewModels.BreadcrumbItemViewModel { Label = "Asset Types", Url = Url.Action("Index") },
        new AssetManagement.Web.ViewModels.BreadcrumbItemViewModel { Label = "Create Asset Type" }
    }
})
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@returnUrl" />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    <div class="mb-3">
        @Html.LabelFor(m => m.AssetCategoryId, new { @class = "form-label" })
        @Html.DropDownListFor(m => m.AssetCategoryId, categories, "-- Select category --", new { @class = "form-select" })
        @Html.ValidationMessageFor(m => m.AssetCategoryId, "", new { @class = "text-danger" })
    </div>
    <div class="mb-3">
        @Html.LabelFor(m => m.Name, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
    </div>
    <div class="mb-3">
        @Html.LabelFor(m => m.Description, new { @class = "form-label" })
        @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = "3" })
    </div>
    <div class="form-check mb-3">
        @Html.CheckBoxFor(m => m.IsActive, new { @class = "form-check-input" })
        @Html.LabelFor(m => m.IsActive, new { @class = "form-check-label" })
    </div>
    @Html.Partial("_TaxonomyUsefulLifeFields")
    @Html.Partial("_FormActions", new AssetManagement.Web.ViewModels.FormActionsViewModel
    {
        SubmitLabel = "Create Asset Type",
        BackUrl = returnUrl,
        BackLabel = "Back"
    })
}
