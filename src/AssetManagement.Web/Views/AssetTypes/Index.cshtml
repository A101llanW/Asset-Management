@model AssetManagement.Web.ViewModels.ListPageViewModel<AssetManagement.Web.ViewModels.AssetTypeVm>
@using System.Collections.Generic
@using AssetManagement.Web.Helpers
@{
    ViewBag.Title = "Asset Types";
    var currentSort = ViewBag.Sort as string;
    var currentDirection = ViewBag.Direction as string;
    var categories = ViewBag.Categories as SelectList;
    var categoryLookup = ViewBag.CategoryLookup as IDictionary<int, string> ?? new Dictionary<int, string>();
}
@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "Asset Types",
    Subtitle = "Manage the type options users can choose within each asset category.",
    PrimaryActionUrl = Url.Action("Create"),
    PrimaryActionLabel = "Create Asset Type"
})
<form class="am-list-toolbar" method="get">
    <div class="row g-2">
        <div class="col-md-5">
            <input type="text" class="form-control" name="search" placeholder="Search by type, description, or category" value="@Model.Search" />
        </div>
        <div class="col-md-3">
            @Html.DropDownList("categoryId", categories, "All categories", new { @class = "form-select" })
        </div>
        <div class="col-md-2">
            <select class="form-select" name="pageSize">
                @foreach (var size in new[] { 10, 25, 50 })
                {
                    <option value="@size" selected="@(Model.PageSize == size)">@size per page</option>
                }
            </select>
        </div>
        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-outline-primary">Apply</button>
        </div>
    </div>
</form>
@if (!Model.Items.Any())
{
    <div class="card card-kpi">
        <div class="card-body am-empty-state">
            <h5>No asset types yet</h5>
            <p class="text-muted mb-3">Create asset types under a category so users can classify assets consistently.</p>
            <a class="btn btn-primary" href="@Url.Action("Create")">Create Asset Type</a>
        </div>
    </div>
}
else
{
    <div class="card card-kpi">
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead class="table-light">
                    <tr>
                        <th>@Html.SortLink("Asset Type", "name", currentSort, currentDirection)</th>
                        <th>@Html.SortLink("Category", "category", currentSort, currentDirection)</th>
                        <th>Description</th>
                        <th>@Html.SortLink("Status", "status", currentSort, currentDirection)</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@(categoryLookup.ContainsKey(item.AssetCategoryId) ? categoryLookup[item.AssetCategoryId] : "Unknown")</td>
                        <td>@item.Description</td>
                        <td><span class="badge bg-@StatusHtmlHelpers.ToBadgeClass(item.IsActive) badge-status">@(item.IsActive ? "Active" : "Inactive")</span></td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", new { id = item.Id, returnUrl = Request.RawUrl })">Details</a>
                            <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Edit", new { id = item.Id, returnUrl = Request.RawUrl })">Edit</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    @Html.Partial("_Pagination", new AssetManagement.Web.ViewModels.PaginationViewModel { Page = Model.Page, TotalPages = Model.TotalPages, TotalCount = Model.TotalCount, StartItem = Model.StartItem, EndItem = Model.EndItem })
}
