@model AssetManagement.Web.ViewModels.AssetTypeVm
@using AssetManagement.Web.Helpers
@{
    ViewBag.Title = "Asset Type Details";
    var returnUrl = ViewBag.ReturnUrl as string ?? Url.Action("Index");
}
@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = Model.Name,
    Subtitle = "Asset type setup and category dependency.",
    BackUrl = returnUrl,
    BackLabel = "Back",
    PrimaryActionUrl = Url.Action("Edit", new { id = Model.Id, returnUrl = Request.RawUrl }),
    PrimaryActionLabel = "Edit Asset Type",
    Breadcrumbs = new[]
    {
        new AssetManagement.Web.ViewModels.BreadcrumbItemViewModel { Label = "Asset Types", Url = Url.Action("Index") },
        new AssetManagement.Web.ViewModels.BreadcrumbItemViewModel { Label = Model.Name }
    }
})
<div class="row g-3">
    <div class="col-lg-4">
        <div class="card card-kpi h-100">
            <div class="card-header">Overview</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Category</dt>
                    <dd class="col-sm-7">@ViewBag.CategoryName</dd>
                    <dt class="col-sm-5">Status</dt>
                    <dd class="col-sm-7"><span class="badge bg-@StatusHtmlHelpers.ToBadgeClass(Model.IsActive) badge-status">@(Model.IsActive ? "Active" : "Inactive")</span></dd>
                    <dt class="col-sm-5">Assets</dt>
                    <dd class="col-sm-7">@ViewBag.AssetCount</dd>
                    <dt class="col-sm-5">Useful life</dt>
                    <dd class="col-sm-7">
                        @if (Model.UseCustomUsefulLife && Model.UsefulLifeMonths.HasValue)
                        {
                            @:@(Model.UsefulLifeMonths) months (custom override)
                        }
                        else if (ViewBag.CategoryDefaultUsefulLifeMonths != null)
                        {
                            @:@ViewBag.CategoryDefaultUsefulLifeMonths months (from category)
                        }
                        else
                        {
                            @:Not set
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card card-kpi">
            <div class="card-header">Description</div>
            <div class="card-body">
                <p class="mb-0">@(string.IsNullOrWhiteSpace(Model.Description) ? "No type description has been added yet." : Model.Description)</p>
            </div>
        </div>
    </div>
</div>
