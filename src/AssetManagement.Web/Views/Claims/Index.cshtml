@model AssetManagement.Web.ViewModels.ListPageViewModel<AssetManagement.Application.ViewModels.ClaimListVm>
@using AssetManagement.Web.Helpers
@{
    ViewBag.Title = "Insurance Claims";
    var canCreate = Html.HasPermission("Claims.Create");
    var assetId = ViewBag.AssetId as int?;
}
@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "Insurance Claims",
    Subtitle = "Track claims linked to insured assets and related incidents.",
    PrimaryActionUrl = canCreate && assetId.HasValue ? Url.Action("Create", new { assetId = assetId.Value }) : null,
    PrimaryActionLabel = canCreate && assetId.HasValue ? "New Claim" : null
})
<form class="am-list-toolbar" method="get">
    <div class="row g-2">
        <div class="col-md-8">
            <input type="text" class="form-control" name="search" placeholder="Search claim number, insurer, or asset" value="@Model.Search" />
        </div>
        @if (assetId.HasValue)
        {
            <input type="hidden" name="assetId" value="@assetId" />
        }
        <div class="col-md-2">
            <select class="form-select" name="pageSize">
                @foreach (var size in new[] { 10, 25, 50 })
                {
                    <option value="@size" selected="@(Model.PageSize == size)">@size per page</option>
                }
            </select>
        </div>
        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-outline-primary">Apply</button>
        </div>
    </div>
</form>
@if (!Model.Items.Any())
{
    <div class="card card-kpi"><div class="card-body am-empty-state">
        <h5>No claims on file</h5>
        <p class="text-muted mb-0">Claims initiated from asset profiles will appear here.</p>
    </div></div>
}
else
{
    <div class="card card-kpi"><div class="card-body p-0">
        <table class="table table-striped mb-0">
            <thead><tr><th>Claim #</th><th>Asset</th><th>Type</th><th>Insurer</th><th>Status</th><th>Date</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.ClaimNumber</td>
                    <td>@(item.AssetTag ?? DisplayText.Empty) - @(item.AssetName ?? "")</td>
                    <td>@item.ClaimType</td>
                    <td>@item.Insurer</td>
                    <td>@item.ClaimStatus</td>
                    <td>@item.ClaimDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-end"><a href="@Url.Action("Details", new { id = item.Id })">View</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div></div>
    @Html.Partial("_Pagination", new AssetManagement.Web.ViewModels.PaginationViewModel { Page = Model.Page, TotalPages = Model.TotalPages, TotalCount = Model.TotalCount, StartItem = Model.StartItem, EndItem = Model.EndItem })
}
