@model AssetManagement.Application.ViewModels.ClaimDetailsVm
@{
    ViewBag.Title = "Claim " + Model.ClaimNumber;
    var canEdit = ViewBag.CanEdit == true;
}
@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "Claim " + Model.ClaimNumber,
    Subtitle = Model.ClaimType + " - " + Model.ClaimStatus,
    BackUrl = Url.Action("Index"),
    BackLabel = "Back to Claims",
    PrimaryActionUrl = Url.Action("Details", "Assets", new { id = Model.AssetId }),
    PrimaryActionLabel = "View Asset"
})
<div class="card card-kpi am-fade-in">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Asset</dt><dd class="col-sm-9"><a href="@Url.Action("Details", "Assets", new { id = Model.AssetId })">@Model.AssetTag - @Model.AssetName</a></dd>
            <dt class="col-sm-3">Linked incident</dt>
            <dd class="col-sm-9">
                @if (Model.IncidentId.HasValue)
                {
                    <a href="@Url.Action("Details", "Incidents", new { id = Model.IncidentId })">@(Model.IncidentNumber ?? ("#" + Model.IncidentId))</a>
                }
                else
                {
                    <text></text>
                }
            </dd>
            <dt class="col-sm-3">Type</dt><dd class="col-sm-9">@Model.ClaimType</dd>
            <dt class="col-sm-3">Insurer</dt><dd class="col-sm-9">@Model.Insurer</dd>
            <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.ClaimStatus</dd>
            <dt class="col-sm-3">Claim date</dt><dd class="col-sm-9">@Model.ClaimDate.ToString("yyyy-MM-dd")</dd>
            <dt class="col-sm-3">Approved amount</dt><dd class="col-sm-9">@Html.FormatCurrency(Model.ApprovedAmount)</dd>
            @if (Model.SettlementDate.HasValue)
            {
                <dt class="col-sm-3">Settlement</dt><dd class="col-sm-9">@Model.SettlementDate.Value.ToString("yyyy-MM-dd") - @(Model.SettlementNotes ?? "")</dd>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Assessor))
            {
                <dt class="col-sm-3">Assessor</dt><dd class="col-sm-9">@Model.Assessor</dd>
            }
            <dt class="col-sm-3">Created</dt><dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</dd>
        </dl>
        @if (canEdit)
        {
            <hr />
            using (Html.BeginForm("UpdateStatus", "Claims", FormMethod.Post, new { @class = "row g-2" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="col-md-3">
                    <label class="form-label" for="status">Claim status</label>
                    @Html.DropDownList("status", (SelectList)ViewBag.ClaimStatuses, new { @class = "form-select", id = "status", required = "required" })
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="approvedAmount">Approved amount</label>
                    <input class="form-control" id="approvedAmount" name="approvedAmount" type="number" step="0.01" min="0" value="@Model.ApprovedAmount" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="settlementNotes">Settlement notes</label>
                    <input class="form-control" id="settlementNotes" name="settlementNotes" value="@Model.SettlementNotes" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary">Update claim</button>
                </div>
            }
            <p class="text-muted small mb-0 mt-2">Settling a linked claim closes the incident and may restore a damaged asset to In Store.</p>
        }
    </div>
</div>
