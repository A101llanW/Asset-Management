@using System.Linq
@using System.Web.Mvc
@using System.Web.Script.Serialization
@model AssetManagement.Application.ViewModels.AssetTransferVm
@{
    ViewBag.Title = "Transfer Asset";
    var users = ViewBag.Users as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
    var departments = ViewBag.Departments as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
    var assetContext = ViewBag.AssetContext as AssetManagement.Web.ViewModels.AssetWorkflowContextViewModel;
    var approvalSummary = ViewBag.TransferApprovalSummary as string;
    var lockFromFields = ViewBag.LockFromFields == true;
    var lockToDepartment = ViewBag.LockToDepartment == true;
    var fromDepartmentName = ViewBag.FromDepartmentName as string;
    var fromUserName = ViewBag.FromUserName as string;
    var workflowConfig = ViewBag.WorkflowFormConfig as AssetManagement.Web.ViewModels.WorkflowFormConfigVm;
    var serializer = new JavaScriptSerializer();
    var workflowPairsJson = workflowConfig == null ? "[]" : serializer.Serialize(workflowConfig.DepartmentUserPairs);
    var workflowLockedJson = workflowConfig == null ? "[]" : serializer.Serialize(workflowConfig.LockedFields);
    var usersByDepartmentJson = workflowConfig == null ? "{}" : workflowConfig.UsersByDepartmentJson;
}

@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "Transfer Asset",
    Subtitle = "Move the asset to a new custodian or department while preserving the transfer trail.",
    BackUrl = Url.Action("Details", "Assets", new { id = Model.AssetId }),
    BackLabel = "Back to Asset"
})

@Html.Partial("_AssetWorkflowContext", assetContext)

<div class="alert alert-info">
    <strong>Approval path:</strong> @approvalSummary
</div>

@using (Html.BeginForm(null, null, FormMethod.Post, new
{
    data_am_workflow_form = "transfer",
    data_am_users_by_dept = usersByDepartmentJson,
    data_am_dept_user_pairs = workflowPairsJson,
    data_am_locked_fields = workflowLockedJson
}))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(m => m.AssetId)
    <div class="row g-3">
        <div class="col-md-3">
            @Html.LabelFor(m => m.FromUserId, new { @class = "form-label" })
            @if (lockFromFields)
            {
                @Html.HiddenFor(m => m.FromUserId)
                <input type="text" class="form-control" readonly="readonly" value="@(string.IsNullOrWhiteSpace(fromUserName) ? "Current custodian not set" : fromUserName)" />
            }
            else
            {
                @Html.DropDownListFor(m => m.FromUserId, ViewBag.FromUsers as IEnumerable<SelectListItem> ?? users, "-- Use current custodian --", new { @class = "form-select" })
            }
            @Html.ValidationMessageFor(m => m.FromUserId, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.ToUserId, new { @class = "form-label" })
            @Html.DropDownListFor(m => m.ToUserId, users, "-- Select user --", new { @class = "form-select", data_am_user_placeholder = "-- Select user --" })
            <div class="form-text">Only users in the selected target department are listed.</div>
            @Html.ValidationMessageFor(m => m.ToUserId, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.FromDepartmentId, new { @class = "form-label" })
            @if (lockFromFields)
            {
                @Html.HiddenFor(m => m.FromDepartmentId)
                <input type="text" class="form-control" readonly="readonly" value="@(string.IsNullOrWhiteSpace(fromDepartmentName) ? "Not specified" : fromDepartmentName)" />
            }
            else
            {
                @Html.DropDownListFor(m => m.FromDepartmentId, departments, "-- Current department --", new { @class = "form-select" })
            }
            @Html.ValidationMessageFor(m => m.FromDepartmentId, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.ToDepartmentId, new { @class = "form-label" })
            @if (lockToDepartment)
            {
                @Html.HiddenFor(m => m.ToDepartmentId)
                <input type="text" class="form-control" readonly="readonly" value="@(ViewBag.ToDepartmentName as string ?? "Your department")" />
                <div class="form-text">Transfers from your profile are limited to your department.</div>
            }
            else
            {
                @Html.DropDownListFor(m => m.ToDepartmentId, ViewBag.AllDepartments as IEnumerable<SelectListItem> ?? departments, "-- Select department --", new { @class = "form-select" })
            }
            @Html.ValidationMessageFor(m => m.ToDepartmentId, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-6">
            @Html.LabelFor(m => m.ConditionBefore, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.ConditionBefore, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.ConditionBefore, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-6">
            @Html.LabelFor(m => m.ConditionAfter, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.ConditionAfter, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.ConditionAfter, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-12">
            @Html.LabelFor(m => m.Reason, new { @class = "form-label" })
            @Html.TextAreaFor(m => m.Reason, new { @class = "form-control", rows = "2" })
            @Html.ValidationMessageFor(m => m.Reason, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-4">
            <div class="form-check mt-2">
                @Html.CheckBoxFor(m => m.MissingAccessories, new { @class = "form-check-input" })
                @Html.LabelFor(m => m.MissingAccessories, new { @class = "form-check-label" })
            </div>
        </div>
        <div class="col-md-8">
            @Html.LabelFor(m => m.DamageNotes, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.DamageNotes, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.DamageNotes, "", new { @class = "text-danger" })
        </div>
    </div>
    @Html.Partial("_FormActions", new AssetManagement.Web.ViewModels.FormActionsViewModel
    {
        SubmitLabel = "Submit Transfer",
        BackUrl = Url.Action("Details", "Assets", new { id = Model.AssetId }),
        BackLabel = "Back to Asset"
    })
}

@section scripts {
    @Html.Partial("_WorkflowFormScripts")
}
