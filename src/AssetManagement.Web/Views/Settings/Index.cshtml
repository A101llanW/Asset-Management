@model AssetManagement.Application.ViewModels.SettingsVm
@using System.Linq
@using System.Web.Mvc
@{
    ViewBag.Title = "Settings";
}

@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "System Settings",
    Subtitle = "Operational defaults, finance currency, and the approval matrix for requisitions, transfers, and disposals.",
    BackUrl = Url.Action("Index", "Dashboard"),
    BackLabel = "Back to Dashboard"
})

@using (Html.BeginForm("Index", "Settings", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

    <div class="card card-kpi mb-3">
        <div class="card-header">Attachments</div>
        <div class="card-body">
            <div class="mb-3">
                @Html.LabelFor(m => m.AttachmentRootPath, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.AttachmentRootPath, new { @class = "form-control", placeholder = "~/App_Data/Attachments" })
            </div>
        </div>
    </div>

    <div class="card card-kpi mb-3">
        <div class="card-header">Notification Thresholds</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    @Html.LabelFor(m => m.WarrantyThresholdDays, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.WarrantyThresholdDays, new { @class = "form-control", type = "number", min = "0" })
                </div>
                <div class="col-md-4">
                    @Html.LabelFor(m => m.InsuranceThresholdDays, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.InsuranceThresholdDays, new { @class = "form-control", type = "number", min = "0" })
                </div>
                <div class="col-md-4">
                    @Html.LabelFor(m => m.MaintenanceThresholdDays, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.MaintenanceThresholdDays, new { @class = "form-control", type = "number", min = "0" })
                </div>
            </div>
        </div>
    </div>

    <div class="card card-kpi mb-3">
        <div class="card-header">Finance Defaults</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    @Html.LabelFor(m => m.DefaultCurrency, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.DefaultCurrency, new { @class = "form-control text-uppercase", maxlength = "10" })
                </div>
            </div>
            <p class="text-muted small mb-0 mt-3">Useful life defaults are configured per asset category and asset type by company administrators.</p>
        </div>
    </div>

    <div class="card card-kpi mb-3">
        <div class="card-header">Approval Matrix</div>
        <div class="card-body">
            @Html.Partial("_RequisitionWorkflowGuide")
            <p class="text-muted mb-3">Enable approval per process and assign an approver <strong>role and individual</strong> for each stage (up to @AssetManagement.Application.ViewModels.ApprovalWorkflowSettingsHelper.MaxApprovalStages). Roles are defined under <a href="@Url.Action("Index", "Roles")">Roles &amp; Permissions</a>. For requisitions, assign users with <code>Purchases.Approve</code> to the stage role (typically Procurement Officer). Changes apply to <strong>new</strong> requests only.</p>
            @Html.Partial("_ApprovalProcessMatrix", Model.ApprovalProcesses)
        </div>
    </div>

    @Html.Partial("_FormActions", new AssetManagement.Web.ViewModels.FormActionsViewModel
    {
        SubmitLabel = "Save Settings",
        BackUrl = Url.Action("Index", "Dashboard"),
        BackLabel = "Back to Dashboard"
    })
}
