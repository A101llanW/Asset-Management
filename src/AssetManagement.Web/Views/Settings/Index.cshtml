@model AssetManagement.Application.ViewModels.SettingsVm
@{
    ViewBag.Title = "Settings";
}
<h3>Settings</h3>

@using (Html.BeginForm("Index", "Settings", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

    <div class="card card-kpi mb-3">
        <div class="card-header">Attachments</div>
        <div class="card-body">
            <div class="mb-3">
                @Html.LabelFor(m => m.AttachmentRootPath, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.AttachmentRootPath, new { @class = "form-control", placeholder = "~/App_Data/Attachments" })
            </div>
        </div>
    </div>

    <div class="card card-kpi mb-3">
        <div class="card-header">Notification Thresholds</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    @Html.LabelFor(m => m.WarrantyThresholdDays, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.WarrantyThresholdDays, new { @class = "form-control", type = "number", min = "0" })
                </div>
                <div class="col-md-4">
                    @Html.LabelFor(m => m.InsuranceThresholdDays, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.InsuranceThresholdDays, new { @class = "form-control", type = "number", min = "0" })
                </div>
                <div class="col-md-4">
                    @Html.LabelFor(m => m.MaintenanceThresholdDays, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.MaintenanceThresholdDays, new { @class = "form-control", type = "number", min = "0" })
                </div>
            </div>
        </div>
    </div>

    <div class="card card-kpi mb-3">
        <div class="card-header">Finance Defaults</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    @Html.LabelFor(m => m.DefaultCurrency, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.DefaultCurrency, new { @class = "form-control text-uppercase", maxlength = "10" })
                </div>
                <div class="col-md-4">
                    @Html.LabelFor(m => m.DefaultUsefulLifeMonths, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.DefaultUsefulLifeMonths, new { @class = "form-control", type = "number", min = "1" })
                </div>
            </div>
        </div>
    </div>

    <div class="card card-kpi mb-3">
        <div class="card-header">Approvals</div>
        <div class="card-body">
            <div class="form-check mb-2">
                @Html.CheckBoxFor(m => m.RequireTransferApproval, new { @class = "form-check-input" })
                @Html.LabelFor(m => m.RequireTransferApproval, new { @class = "form-check-label" })
            </div>
            <div class="form-check">
                @Html.CheckBoxFor(m => m.RequireDisposalApproval, new { @class = "form-check-input" })
                @Html.LabelFor(m => m.RequireDisposalApproval, new { @class = "form-check-label" })
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save Settings</button>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Dashboard")">Back to Dashboard</a>
    </div>
}
