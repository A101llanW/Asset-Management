@model AssetManagement.Web.ViewModels.ListPageViewModel<AssetManagement.Application.ViewModels.SupplierVm>
@using AssetManagement.Web.Helpers
@{
    ViewBag.Title = "Suppliers";
    var canCreateSupplier = Html.HasPermission("Suppliers.Create");
    var canEditSupplier = Html.HasPermission("Suppliers.Edit");
    var currentSort = ViewBag.Sort as string;
    var currentDirection = ViewBag.Direction as string;
}
@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "Suppliers",
    Subtitle = "Keep approved vendors up to date for purchasing and asset sourcing.",
    PrimaryActionUrl = canCreateSupplier ? Url.Action("Create") : null,
    PrimaryActionLabel = canCreateSupplier ? "Create Supplier" : null
})
<form class="am-list-toolbar" method="get">
    <div class="row g-2">
        <div class="col-md-8">
            <input type="text" class="form-control" name="search" placeholder="Search by supplier, contact, email, or phone" value="@Model.Search" />
        </div>
        <div class="col-md-2">
            <select class="form-select" name="pageSize">
                @foreach (var size in new[] { 10, 25, 50 })
                {
                    <option value="@size" selected="@(Model.PageSize == size)">@size per page</option>
                }
            </select>
        </div>
        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-outline-primary">Apply</button>
        </div>
    </div>
</form>
@if (!Model.Items.Any())
{
    <div class="card card-kpi">
        <div class="card-body am-empty-state">
            <h5>No suppliers yet</h5>
            <p class="text-muted mb-3">Add suppliers before creating purchase records so procurement history stays complete.</p>
            @if (canCreateSupplier)
            {
                <a class="btn btn-primary" href="@Url.Action("Create")">Create Supplier</a>
            }
        </div>
    </div>
}
else
{
    <div class="card card-kpi"><div class="card-body p-0">
    <table class="table mb-0">
        <thead class="table-light"><tr><th>@Html.SortLink("Name", "name", currentSort, currentDirection)</th><th>@Html.SortLink("Contact", "contact", currentSort, currentDirection)</th><th>Email</th><th>Phone</th><th>@Html.SortLink("Status", "status", currentSort, currentDirection)</th><th></th></tr></thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.SupplierName</td>
                <td>@item.ContactPerson</td>
                <td>@item.Email</td>
                <td>@item.Phone</td>
                <td><span class="badge bg-@StatusHtmlHelpers.ToBadgeClass(item.IsActive) badge-status">@(item.IsActive ? "Active" : "Inactive")</span></td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", new { id = item.Id, returnUrl = Request.RawUrl })">Details</a>
                    @if (canEditSupplier)
                    {
                        <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Edit", new { id = item.Id, returnUrl = Request.RawUrl })">Edit</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
    </div></div>
    @Html.Partial("_Pagination", new AssetManagement.Web.ViewModels.PaginationViewModel { Page = Model.Page, TotalPages = Model.TotalPages, TotalCount = Model.TotalCount, StartItem = Model.StartItem, EndItem = Model.EndItem })
}
