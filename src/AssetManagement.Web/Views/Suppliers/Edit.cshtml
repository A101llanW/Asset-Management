@model AssetManagement.Application.ViewModels.SupplierVm
@{
    ViewBag.Title = "Edit Supplier";
}
<h3>Edit Supplier</h3>
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Id)
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    <div class="row g-3">
        <div class="col-md-6">@Html.LabelFor(m => m.SupplierName, new { @class = "form-label" }) @Html.TextBoxFor(m => m.SupplierName, new { @class = "form-control" })</div>
        <div class="col-md-6">@Html.LabelFor(m => m.ContactPerson, new { @class = "form-label" }) @Html.TextBoxFor(m => m.ContactPerson, new { @class = "form-control" })</div>
        <div class="col-md-6">@Html.LabelFor(m => m.Email, new { @class = "form-label" }) @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })</div>
        <div class="col-md-6">@Html.LabelFor(m => m.Phone, new { @class = "form-label" }) @Html.TextBoxFor(m => m.Phone, new { @class = "form-control" })</div>
        <div class="col-md-12">@Html.LabelFor(m => m.Address, new { @class = "form-label" }) @Html.TextAreaFor(m => m.Address, new { @class = "form-control", rows = "2" })</div>
        <div class="col-md-12">@Html.LabelFor(m => m.Notes, new { @class = "form-label" }) @Html.TextAreaFor(m => m.Notes, new { @class = "form-control", rows = "2" })</div>
        <div class="col-md-12 form-check">@Html.CheckBoxFor(m => m.IsActive, new { @class = "form-check-input" }) @Html.LabelFor(m => m.IsActive, new { @class = "form-check-label" })</div>
    </div>
    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Update Supplier</button>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Back to Suppliers</a>
    </div>
}
