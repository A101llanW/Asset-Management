<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Asset Management – Public asset information portal." />
    <title>@ViewBag.Title - Asset Management</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="@Url.Content("~/Content/bootstrap.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Content/css/site.css")?v=@System.IO.File.GetLastWriteTimeUtc(Server.MapPath("~/Content/css/site.css")).Ticks" />
    <link rel="stylesheet" href="@Url.Content("~/Content/css/am-modules.css")?v=@System.IO.File.GetLastWriteTimeUtc(Server.MapPath("~/Content/css/am-modules.css")).Ticks" />
    @RenderSection("head", required: false)
</head>
<body class="am-public-scan-body">

    <div class="am-public-shell">

        <header class="am-public-header">
            <div class="am-public-brand">
                <span class="am-public-brand-mark">AM</span>
                <div class="am-public-brand-copy">
                    <span class="am-public-brand-kicker">Nanosoft Asset Suite</span>
                    <span class="am-public-brand-name">Asset Management</span>
                </div>
            </div>
            <span class="am-public-header-badge">Public Portal</span>
        </header>

        <main class="am-public-main">
            <div class="am-public-scan-container">
                @RenderBody()
            </div>
        </main>

        <footer class="am-public-footer">
            <a class="am-public-signin-link" href="@Url.RouteUrl("Default", new { controller = "Account", action = "Login", returnUrl = Request.RawUrl })">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="vertical-align:-1px;margin-right:0.35rem"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                Staff sign in
            </a>
            <span class="am-public-footer-divider" aria-hidden="true">·</span>
            <span class="am-public-footer-copy">&copy; @DateTime.Now.Year Nanosoft Asset Suite</span>
        </footer>

    </div>

    @RenderSection("scripts", required: false)

</body>
</html>
