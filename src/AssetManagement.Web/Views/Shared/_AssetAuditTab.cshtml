@using AssetManagement.Application.ViewModels
@{
    var auditLogs = ViewBag.AssetAuditLogs as IEnumerable<AuditLogVm> ?? Enumerable.Empty<AuditLogVm>();
    var assetId = ViewBag.AssetId as int?;
    var canViewAuditLogs = Html.HasPermission("AuditLogs.View");
}

<div class="card card-kpi">
    <div class="card-body">
        <h6 class="mb-3">Audit trail</h6>
        <p class="text-muted small">System activity recorded for this asset.</p>

        @if (auditLogs.Any())
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>When</th>
                            <th>Action</th>
                            <th>Actor</th>
                            <th>IP</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var entry in auditLogs)
                    {
                        <tr>
                            <td>@entry.Timestamp.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(string.IsNullOrWhiteSpace(entry.ActionLabel) ? entry.Action : entry.ActionLabel)</td>
                            <td>@entry.ActorUserId</td>
                            <td>@(string.IsNullOrWhiteSpace(entry.IPAddress) ? "—" : entry.IPAddress)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No audit entries are recorded for this asset yet.</p>
        }

        @if (canViewAuditLogs && assetId.HasValue)
        {
            <div class="mt-3">
                <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Index", "AuditLogs", new { RelatedAssetId = assetId.Value })">Open full audit log</a>
            </div>
        }
        else if (canViewAuditLogs)
        {
            <div class="mt-3">
                <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Index", "AuditLogs")">Open full audit log</a>
            </div>
        }
    </div>
</div>
