@model AssetManagement.Web.ViewModels.AssetWorkflowContextViewModel
@if (Model != null)
{
    <div class="card card-kpi mb-3 am-context-card">
        <div class="card-header">Asset Context</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="text-muted small">Asset</div>
                    <div class="fw-semibold">@Model.AssetName</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted small">Tag</div>
                    <div class="fw-semibold">@Model.AssetTag</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted small">Status</div>
                    <div class="fw-semibold">@Model.Status</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted small">Department</div>
                    <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.DepartmentName) ? "Not set" : Model.DepartmentName)</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small">Custodian</div>
                    <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.CustodianName) ? "Not assigned" : Model.CustodianName)</div>
                </div>
            </div>
        </div>
    </div>
}
