@using AssetManagement.Web.Helpers
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Asset Management Module</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/Content/css/site.css" />
</head>
<body>
    @{
        string currentController = ViewContext.RouteData.Values["controller"] != null
            ? ViewContext.RouteData.Values["controller"].ToString()
            : string.Empty;
    }

    <header class="am-shell-header">
        <div class="am-header-inner">
            <div class="am-header-branding">
                @if (Request.IsAuthenticated)
                {
                    <button type="button" id="amSidebarToggle" class="am-menu-button" aria-label="Open menu" aria-controls="amSidebar" aria-expanded="false">
                        <span class="am-menu-button-dot"></span>
                        <span class="am-menu-button-dot"></span>
                        <span class="am-menu-button-dot"></span>
                    </button>
                }
                <a class="am-brand" href="@Url.Action("Landing", "Account")">
                    <span class="am-brand-mark">AM</span>
                    <span class="am-brand-copy">
                        <small class="am-brand-kicker">Nanosoft Asset Suite</small>
                        <span class="am-brand-title">Asset Management Module</span>
                    </span>
                </a>
            </div>

            @if (Request.IsAuthenticated)
            {
                <div class="am-header-user">
                    <span class="am-header-user-label">Welcome</span>
                    <strong class="am-header-user-name">@User.Identity.Name</strong>
                </div>
            }
        </div>
    </header>

    @if (Request.IsAuthenticated)
    {
        <div id="amSidebarOverlay" class="am-sidebar-overlay" aria-hidden="true"></div>

        <aside id="amSidebar" class="am-sidebar" aria-hidden="true">
            <div class="am-sidebar-header">
                <a class="am-sidebar-brand" href="@Url.Action("Landing", "Account")">Asset Management Module</a>
            </div>

            <nav class="am-sidebar-nav">
                <ul class="nav flex-column">
                    @if (Html.HasPermission("Reports.View"))
                    {
                        <li class="nav-item"><a class="nav-link @(currentController == "Dashboard" ? "active" : string.Empty)" href="@Url.Action("Index", "Dashboard")">Dashboard</a></li>
                    }
                    @if (Html.HasPermission("Assets.View"))
                    {
                        <li class="nav-item"><a class="nav-link @(currentController == "Assets" ? "active" : string.Empty)" href="@Url.Action("Index", "Assets")">Assets</a></li>
                    }
                    @if (Html.HasPermission("Purchases.View"))
                    {
                        <li class="nav-item"><a class="nav-link @(currentController == "Purchases" ? "active" : string.Empty)" href="@Url.Action("Index", "Purchases")">Purchases</a></li>
                    }
                    @if (Html.HasPermission("Departments.View"))
                    {
                        <li class="nav-item"><a class="nav-link @(currentController == "Departments" ? "active" : string.Empty)" href="@Url.Action("Index", "Departments")">Departments</a></li>
                    }
                    @if (Html.HasPermission("Suppliers.View"))
                    {
                        <li class="nav-item"><a class="nav-link @(currentController == "Suppliers" ? "active" : string.Empty)" href="@Url.Action("Index", "Suppliers")">Suppliers</a></li>
                    }
                    @if (Html.HasPermission("Users.View"))
                    {
                        <li class="nav-item"><a class="nav-link @(currentController == "Users" ? "active" : string.Empty)" href="@Url.Action("Index", "Users")">Users</a></li>
                    }
                    @if (Html.HasPermission("Roles.View"))
                    {
                        <li class="nav-item"><a class="nav-link @(currentController == "Roles" || currentController == "Permissions" ? "active" : string.Empty)" href="@Url.Action("Index", "Roles")">Roles & Permissions</a></li>
                    }
                    @if (Html.HasPermission("AuditLogs.View"))
                    {
                        <li class="nav-item"><a class="nav-link @(currentController == "AuditLogs" ? "active" : string.Empty)" href="@Url.Action("Index", "AuditLogs")">Audit Logs</a></li>
                    }
                    @if (Html.HasPermission("Reports.View"))
                    {
                        <li class="nav-item"><a class="nav-link @(currentController == "Notifications" ? "active" : string.Empty)" href="@Url.Action("Index", "Notifications")">Notifications</a></li>
                    }
                    @if (Html.HasPermission("Settings.Manage"))
                    {
                        <li class="nav-item"><a class="nav-link @(currentController == "Settings" ? "active" : string.Empty)" href="@Url.Action("Index", "Settings")">Settings</a></li>
                    }
                </ul>
            </nav>

            <div class="am-sidebar-footer">
                <span class="am-user-name">@User.Identity.Name</span>
                @using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { @class = "mb-0" }))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-light w-100">Logout</button>
                }
            </div>
        </aside>
    }

    <main class="container-fluid px-4 py-3 am-main-content">
        @Html.Partial("_Alerts")
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/app/permissions.js"></script>

    @if (Request.IsAuthenticated)
    {
        <script>
            (function () {
                var body = document.body;
                var toggle = document.getElementById("amSidebarToggle");
                var sidebar = document.getElementById("amSidebar");
                var overlay = document.getElementById("amSidebarOverlay");

                if (!toggle || !sidebar || !overlay) {
                    return;
                }

                function setSidebarState(isOpen) {
                    if (isOpen) {
                        body.classList.add("am-sidebar-open");
                    } else {
                        body.classList.remove("am-sidebar-open");
                    }

                    toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
                    sidebar.setAttribute("aria-hidden", isOpen ? "false" : "true");
                    overlay.setAttribute("aria-hidden", isOpen ? "false" : "true");
                }

                toggle.addEventListener("click", function () {
                    setSidebarState(!body.classList.contains("am-sidebar-open"));
                });

                overlay.addEventListener("click", function () {
                    setSidebarState(false);
                });

                document.addEventListener("keydown", function (event) {
                    if (event.key === "Escape") {
                        setSidebarState(false);
                    }
                });

                var links = sidebar.querySelectorAll(".nav-link");
                for (var i = 0; i < links.length; i++) {
                    links[i].addEventListener("click", function () {
                        setSidebarState(false);
                    });
                }
            })();
        </script>
    }

    @RenderSection("scripts", required: false)
</body>
</html>
