@model AssetManagement.Application.ViewModels.AssetDetailsVm
@using System
@using System.Linq
@using AssetManagement.Application.Helpers
@using AssetManagement.Web.Helpers
@{
    var canUpload = Html.CanUploadAssetDocument(Model.CurrentCustodianId);
    var canDownload = Html.CanDownloadAssetDocument(Model.CurrentCustodianId);
    var canDelete = Html.HasPermission("Documents.Delete");
    var existingTypes = Model.Documents == null
        ? Enumerable.Empty<string>()
        : Model.Documents.Select(x => x.DocumentType);
    var catalogGroups = AssetDocumentTypeCatalog.GetStandardGroups();
    var additionalTypes = AssetDocumentTypeCatalog.GetAllSuggestedTypes(existingTypes)
        .Where(x => !catalogGroups.SelectMany(g => g.Types).Contains(x, StringComparer.OrdinalIgnoreCase))
        .ToList();
    var documents = Model.Documents == null ? Enumerable.Empty<AssetManagement.Application.ViewModels.AssetDocumentVm>() : Model.Documents;
}

<div class="card card-kpi">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <div>
                <h6 class="mb-0 fw-semibold">Asset documents</h6>
                <p class="text-muted small mb-0">Supporting files such as invoices, warranties, condition photos, and compliance certificates.</p>
            </div>
            @if (canUpload)
            {
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#assetDocumentUploadModal">Upload documents</button>
            }
        </div>

        <div class="table-responsive">
            <table class="table table-striped mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Document type</th>
                        <th>File</th>
                        <th>Size</th>
                        <th>Uploaded</th>
                        <th>By</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @if (!documents.Any())
                {
                    <tr>
                        <td colspan="6" class="text-muted">No documents uploaded for this asset yet.</td>
                    </tr>
                }
                else
                {
                    foreach (var doc in documents)
                    {
                        <tr>
                            <td>@(doc.DocumentType ?? "General")</td>
                            <td>@doc.FileName</td>
                            <td>@((doc.FileSizeBytes / 1024.0).ToString("N0")) KB</td>
                            <td>@doc.UploadedAt.ToString("yyyy-MM-dd")</td>
                            <td>@(doc.UploadedByName ?? DisplayText.Empty)</td>
                            <td class="text-end text-nowrap">
                                @if (canDownload)
                                {
                                    <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Download", "Documents", new { id = doc.Id })">Download</a>
                                }
                                @if (canDelete)
                                {
                                    <form action="@Url.Action("Delete", "Documents")" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@doc.Id" />
                                        <input type="hidden" name="assetId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this document?');">Delete</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (canUpload)
{
    <div class="modal fade" id="assetDocumentUploadModal" tabindex="-1" aria-labelledby="assetDocumentUploadModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <form action="@Url.Action("Upload", "Documents")" method="post" enctype="multipart/form-data" data-am-document-upload-form>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="assetId" value="@Model.Id" />
                    <input type="hidden" name="documentType" id="DocumentType" value="" />
                    <div class="modal-header">
                        <h5 class="modal-title" id="assetDocumentUploadModalLabel">Upload document</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label" for="DocumentTypeSelect">Document type</label>
                            <select class="form-select" id="DocumentTypeSelect" required="required">
                                <option value="">-- Select document type --</option>
                                @foreach (var group in catalogGroups)
                                {
                                    var requiresPhotoName = string.Equals(group.Name, AssetDocumentTypeCatalog.PhotosMediaGroupName, StringComparison.OrdinalIgnoreCase);
                                    <optgroup label="@group.Name">
                                        @foreach (var type in group.Types)
                                        {
                                            <option value="@type" data-am-requires-photo-name="@(requiresPhotoName ? "true" : "false")">@type</option>
                                        }
                                    </optgroup>
                                }
                                @if (additionalTypes.Any())
                                {
                                    <optgroup label="Previously used on this asset">
                                        @foreach (var type in additionalTypes)
                                        {
                                            <option value="@type">@type</option>
                                        }
                                    </optgroup>
                                }
                                <option value="@AssetDocumentTypeCatalog.CustomOptionValue">Other (enter name)</option>
                            </select>
                            <div class="form-text">Choose the category that best describes this file.</div>
                        </div>
                        <div class="mb-3" id="DocumentTypeCustomWrap" hidden="hidden">
                            <label class="form-label" for="DocumentTypeCustom">Custom document name</label>
                            <input class="form-control" type="text" id="DocumentTypeCustom" maxlength="100" placeholder="e.g. Board approval letter, Site photo pack" />
                            <div class="form-text">Use when the document type is not listed above.</div>
                        </div>
                        <div class="mb-3" id="DocumentPhotoNameWrap" hidden="hidden">
                            <label class="form-label" for="DocumentPhotoName">Photo name</label>
                            <input class="form-control" type="text" id="DocumentPhotoName" maxlength="100" placeholder="e.g. condition before photo, front panel damage" />
                            <div class="form-text">Describe this photo so it is easy to find later.</div>
                        </div>
                        <div class="mb-0">
                            <label class="form-label" for="DocumentAttachment">File</label>
                            <input type="file" class="form-control" id="DocumentAttachment" name="attachment" accept=".pdf,.jpg,.jpeg,.png,.gif,.doc,.docx,.xls,.xlsx,.txt,image/*" required="required" />
                            <div class="form-text">PDF, images, Office documents, or text up to 10 MB.</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Upload</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
