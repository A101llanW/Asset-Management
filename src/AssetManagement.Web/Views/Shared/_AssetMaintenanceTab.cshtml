@model AssetManagement.Application.ViewModels.AssetDetailsVm
@using AssetManagement.Domain.Enums
@{
    var canEditAsset = ViewData["CanEditAsset"] as bool? ?? false;
}
<div class="card card-kpi">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="mb-0">Maintenance history</h6>
            @if (canEditAsset)
            {
                <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Create", "Maintenance", new { assetId = Model.Id })">Create ticket</a>
            }
        </div>
        @if (Model.MaintenanceRecords == null || !Model.MaintenanceRecords.Any())
        {
            <p class="text-muted mb-0">No maintenance tickets for this asset.</p>
        }
        else
        {
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Ticket</th>
                        <th>Type</th>
                        <th>Issue</th>
                        <th>Status</th>
                        <th>Opened</th>
                        <th>Returned</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var ticket in Model.MaintenanceRecords)
                {
                    var isOpen = ticket.Status == MaintenanceStatus.Open || ticket.Status == MaintenanceStatus.InProgress;
                    <tr>
                        <td>@ticket.MaintenanceTicketNumber</td>
                        <td>@ticket.MaintenanceType</td>
                        <td>@ticket.ReportedIssue</td>
                        <td><span class="badge bg-@(isOpen ? "warning" : "secondary")">@ticket.Status</span></td>
                        <td>@ticket.ServiceDate.ToString("yyyy-MM-dd")</td>
                        <td>@(ticket.CompletionDate.HasValue ? ticket.CompletionDate.Value.ToString("yyyy-MM-dd") : DisplayText.Empty)</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", "Maintenance", new { id = ticket.Id })">View</a>
                            @if (canEditAsset && isOpen)
                            {
                                <a class="btn btn-sm btn-outline-success ms-1" href="@Url.Action("Complete", "Maintenance", new { id = ticket.Id })">Complete</a>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
