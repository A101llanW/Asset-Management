@model AssetManagement.Web.ViewModels.ListPageViewModel<AssetManagement.Application.ViewModels.RoleVm>
@using AssetManagement.Application.ViewModels
@using AssetManagement.Web.Helpers
@{
    ViewBag.Title = "Roles";
    var canCreateRole = Html.HasPermission("Roles.Create");
    var canEditRole = Html.HasPermission("Roles.Edit");
    var canManageSettings = Html.HasPermission("Settings.Manage");
    var statusFilter = ViewBag.StatusFilter as SelectList;
    var currentSort = ViewBag.Sort as string;
    var currentDirection = ViewBag.Direction as string;
}
@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "Roles",
    Subtitle = "Access profiles for approvers and submitters. Roles selected here appear as approval stages under Settings.",
    PrimaryActionUrl = canCreateRole ? Url.Action("Create") : null,
    PrimaryActionLabel = canCreateRole ? "Create Role" : null
})
@if (canManageSettings)
{
    @Html.Partial("_RequisitionWorkflowGuide")
}
<form class="am-list-toolbar" method="get">
    <div class="row g-2">
        <div class="col-md-7">
            <input type="text" class="form-control" name="search" placeholder="Search by role name or description" value="@Model.Search" />
        </div>
        <div class="col-md-2">
            @Html.DropDownList("isActive", statusFilter, new { @class = "form-select" })
        </div>
        <div class="col-md-2">
            <select class="form-select" name="pageSize">
                @foreach (var size in new[] { 10, 25, 50 })
                {
                    <option value="@size" selected="@(Model.PageSize == size)">@size per page</option>
                }
            </select>
        </div>
        <div class="col-md-1 d-grid">
            <button type="submit" class="btn btn-outline-primary">Apply</button>
        </div>
    </div>
</form>
@if (!Model.Items.Any())
{
    <div class="card card-kpi">
        <div class="card-body am-empty-state">
            <h5>No roles yet</h5>
            <p class="text-muted mb-3">Create a role before assigning permissions to users and teams.</p>
            @if (canCreateRole)
            {
                <a class="btn btn-primary" href="@Url.Action("Create")">Create Role</a>
            }
        </div>
    </div>
}
else
{
    <div class="card card-kpi"><div class="card-body p-0">
    <table class="table mb-0">
        <thead class="table-light"><tr><th>@Html.SortLink("Name", "name", currentSort, currentDirection)</th><th>Workflow</th><th>Description</th><th>@Html.SortLink("System", "system", currentSort, currentDirection)</th><th>@Html.SortLink("Status", "status", currentSort, currentDirection)</th><th></th></tr></thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            var workflowNote = ApprovalWorkflowSettingsHelper.GetTypicalRoleWorkflowNote(item.Name);
            <tr>
                <td>@item.Name</td>
                <td class="small text-muted" style="max-width:220px;white-space:normal">@(workflowNote ?? "—")</td>
                <td>@item.Description</td>
                <td>@(item.IsSystemRole ? "Yes" : "No")</td>
                <td><span class="badge bg-@StatusHtmlHelpers.ToBadgeClass(item.IsActive) badge-status">@(item.IsActive ? "Active" : "Inactive")</span></td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", new { id = item.Id, returnUrl = Request.RawUrl })">Details</a>
                    @if (canEditRole)
                    {
                        <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Edit", new { id = item.Id, returnUrl = Request.RawUrl })">Edit</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
    </div></div>
    @Html.Partial("_Pagination", new AssetManagement.Web.ViewModels.PaginationViewModel { Page = Model.Page, TotalPages = Model.TotalPages, TotalCount = Model.TotalCount, StartItem = Model.StartItem, EndItem = Model.EndItem })
}
