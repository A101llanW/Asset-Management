@model AssetManagement.Application.ViewModels.PurchaseRecordVm
@{
    ViewBag.Title = "Create Purchase Record";
    var suppliers = ViewBag.Suppliers as SelectList;
}
<h3>Create Purchase Record</h3>
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-4"><label class="form-label">PO Number</label>@Html.TextBoxFor(m => m.PurchaseOrderNumber, new { @class = "form-control" })</div>
        <div class="col-md-3"><label class="form-label">Supplier</label>@Html.DropDownListFor(m => m.SupplierId, suppliers, "-- Select supplier --", new { @class = "form-select" })</div>
        <div class="col-md-3"><label class="form-label">Invoice #</label>@Html.TextBoxFor(m => m.InvoiceNumber, new { @class = "form-control" })</div>
        <div class="col-md-3"><label class="form-label">Date</label>@Html.TextBoxFor(m => m.PurchaseDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })</div>
        <div class="col-md-2"><label class="form-label">Quantity</label>@Html.TextBoxFor(m => m.Quantity, new { @class = "form-control", type = "number" })</div>
        <div class="col-md-2"><label class="form-label">Unit Cost</label>@Html.TextBoxFor(m => m.UnitCost, new { @class = "form-control", type = "number", step = "0.01" })</div>
        <div class="col-md-2"><label class="form-label">Total Cost</label>@Html.TextBoxFor(m => m.TotalCost, new { @class = "form-control", type = "number", step = "0.01" })</div>
        <div class="col-md-2"><label class="form-label">Currency</label>@Html.TextBoxFor(m => m.Currency, new { @class = "form-control" })</div>
    </div>
    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Create Purchase Record</button>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Back to Purchases</a>
    </div>
}
