@model AssetManagement.Application.ViewModels.AssetReceiveVm
@{
    ViewBag.Title = "Receive Asset";
    var detail = ViewBag.ReceiveDetail as AssetManagement.Application.ViewModels.PurchaseReceiveDetailVm;
    var returnUrl = ViewBag.ReturnUrl as string ?? Url.Action("Details", new { id = Model.PurchaseRecordId });
}
@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "Receive Asset",
    Subtitle = detail != null ? ("PO " + (detail.PurchaseOrderNumber ?? detail.PurchaseRecordId.ToString()) + " - " + detail.RemainingQuantity + " unit(s) remaining") : "Link an in-store asset to this purchase.",
    BackUrl = returnUrl,
    BackLabel = "Back to Purchase"
})

<div class="card card-kpi mb-3">
    <div class="card-body">
        @using (Html.BeginForm("Receive", "Purchases", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.PurchaseRecordId)
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Asset</label>
                    @Html.DropDownListFor(m => m.AssetId, (SelectList)ViewBag.Assets, "Select asset", new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.AssetId, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-3">
                    <label class="form-label">Received Date</label>
                    @Html.TextBoxFor(m => m.ReceivedDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                </div>
                <div class="col-md-3">
                    <label class="form-label">Quantity Received</label>
                    @Html.TextBoxFor(m => m.QuantityReceived, new { @class = "form-control", type = "number", min = "1", max = detail != null ? detail.RemainingQuantity.ToString() : "1" })
                    @Html.ValidationMessageFor(m => m.QuantityReceived, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-6">
                    <label class="form-label">Condition on Receipt</label>
                    @Html.TextBoxFor(m => m.ConditionOnReceipt, new { @class = "form-control" })
                </div>
                <div class="col-md-6">
                    <label class="form-label">Notes</label>
                    @Html.TextAreaFor(m => m.Notes, new { @class = "form-control", rows = "2" })
                </div>
            </div>
            @Html.ValidationSummary(true, "", new { @class = "text-danger mt-2" })
            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Record Receiving</button>
                <a class="btn btn-outline-secondary" href="@returnUrl">Cancel</a>
            </div>
        }
    </div>
</div>
