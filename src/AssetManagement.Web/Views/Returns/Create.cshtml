@using System.Linq
@using System.Web.Mvc
@using System.Web.Script.Serialization
@model AssetManagement.Application.ViewModels.AssetReturnVm
@{
    ViewBag.Title = "Return Asset";
    var users = ViewBag.Users as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
    var assetContext = ViewBag.AssetContext as AssetManagement.Web.ViewModels.AssetWorkflowContextViewModel;
    var lockReturnedBy = ViewBag.LockReturnedBy == true;
    var requireReturnedBy = ViewBag.RequireReturnedBy == true;
    var returnedByName = ViewBag.ReturnedByName as string;
    var receiveDepartmentName = ViewBag.ReceiveDepartmentName as string;
    var workflowConfig = ViewBag.WorkflowFormConfig as AssetManagement.Web.ViewModels.WorkflowFormConfigVm;
    var serializer = new JavaScriptSerializer();
    var workflowLockedJson = workflowConfig == null ? "[]" : serializer.Serialize(workflowConfig.LockedFields);
    var usersByDepartmentJson = workflowConfig == null ? "{}" : workflowConfig.UsersByDepartmentJson;
}

@Html.Partial("_PageHeader", new AssetManagement.Web.ViewModels.PageHeaderViewModel
{
    Title = "Return Asset",
    Subtitle = "Capture the return condition, receiving user, and any missing accessories before closing the handback.",
    BackUrl = Url.Action("Details", "Assets", new { id = Model.AssetId }),
    BackLabel = "Back to Asset"
})

@Html.Partial("_AssetWorkflowContext", assetContext)

@using (Html.BeginForm(null, null, FormMethod.Post, new
{
    data_am_workflow_form = "return",
    data_am_users_by_dept = usersByDepartmentJson,
    data_am_dept_user_pairs = "[]",
    data_am_locked_fields = workflowLockedJson
}))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(m => m.AssetId)
    <div class="row g-3">
        <div class="col-md-4">
            @Html.LabelFor(m => m.ReturnedById, new { @class = "form-label" })
            @if (lockReturnedBy)
            {
                @Html.HiddenFor(m => m.ReturnedById)
                <input type="text" class="form-control" readonly="readonly" value="@(string.IsNullOrWhiteSpace(returnedByName) ? "Current custodian" : returnedByName)" />
            }
            else
            {
                @Html.DropDownListFor(
                    m => m.ReturnedById,
                    users,
                    "-- Select returning user --",
                    new { @class = "form-select", required = "required" })
                <div class="form-text">This asset has no custodian on record (for example, a department pool assignment). Select who is returning it.</div>
            }
            @Html.ValidationMessageFor(m => m.ReturnedById, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-4">
            @Html.LabelFor(m => m.ReceivedById, new { @class = "form-label" })
            @Html.DropDownListFor(m => m.ReceivedById, users, "-- Select user --", new { @class = "form-select" })
            @if (!string.IsNullOrWhiteSpace(receiveDepartmentName))
            {
                <div class="form-text">Receiving users are limited to @receiveDepartmentName.</div>
            }
            @Html.ValidationMessageFor(m => m.ReceivedById, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-4">
            @Html.LabelFor(m => m.ReturnDate, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.ReturnDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
            @Html.ValidationMessageFor(m => m.ReturnDate, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-4">
            <div class="form-check mt-2">
                @Html.CheckBoxFor(m => m.MissingAccessories, new { @class = "form-check-input" })
                @Html.LabelFor(m => m.MissingAccessories, new { @class = "form-check-label" })
            </div>
        </div>
        <div class="col-md-6">
            @Html.LabelFor(m => m.ReturnCondition, new { @class = "form-label" })
            @Html.DropDownListFor(
                m => m.ReturnCondition,
                ViewBag.ConditionOptions as IEnumerable<SelectListItem>,
                "-- Select condition --",
                new { @class = "form-select" })
            @Html.ValidationMessageFor(m => m.ReturnCondition, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-6">
            @Html.LabelFor(m => m.DamageNotes, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.DamageNotes, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.DamageNotes, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-12">
            @Html.LabelFor(m => m.Notes, new { @class = "form-label" })
            @Html.TextAreaFor(m => m.Notes, new { @class = "form-control", rows = "2" })
            @Html.ValidationMessageFor(m => m.Notes, "", new { @class = "text-danger" })
        </div>
    </div>
    @Html.Partial("_FormActions", new AssetManagement.Web.ViewModels.FormActionsViewModel
    {
        SubmitLabel = "Submit Return",
        BackUrl = Url.Action("Details", "Assets", new { id = Model.AssetId }),
        BackLabel = "Back to Asset"
    })
}

@section scripts {
    @Html.Partial("_WorkflowFormScripts")
}
